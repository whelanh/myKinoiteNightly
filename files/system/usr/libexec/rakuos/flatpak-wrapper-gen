#!/usr/bin/env bash
set -euo pipefail

SRC="/var/lib/flatpak/exports/bin"
DEST="/usr/local/bin/flatpak"
OVERRIDE_FILE="/usr/share/rakuos/flatpak-command-overrides.conf"
TAG="# Generated by RakuOS Flatpak Wrapper"

mkdir -p "$DEST"
rm -rf /usr/local/bin/flatpak/*
declare -A OVERRIDES

# -----------------------
# Load overrides file
# -----------------------
if [[ -f "$OVERRIDE_FILE" ]]; then
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        [[ -z "${key// }" ]] && continue
        [[ "$key" =~ ^# ]] && continue
        OVERRIDES["$key"]="$value"
    done < "$OVERRIDE_FILE"
fi

# -----------------------
# Remove old generated wrappers
# -----------------------
for file in "$DEST"/*; do
    [[ -f "$file" ]] || continue
    if head -n1 "$file" 2>/dev/null | grep -q "$TAG"; then
        rm -f "$file"
    fi
done

[[ -d "$SRC" ]] || exit 0

# -----------------------
# Generate wrappers
# -----------------------
for export in "$SRC"/*; do
    [[ -f "$export" ]] || continue

    app_id=$(basename "$export")

    # Use override if present
    if [[ -n "${OVERRIDES[$app_id]:-}" ]]; then
        cmd_name="${OVERRIDES[$app_id]}"
    else
        # Default: last segment, lowercase
        cmd_name=$(echo "$app_id" | awk -F. '{print tolower($NF)}')
    fi

    wrapper="$DEST/$cmd_name"

    # Do not override real system binaries
    if command -v "$cmd_name" >/dev/null 2>&1; then
        real_path=$(command -v "$cmd_name")
        if [[ "$real_path" != "$wrapper" ]]; then
            continue
        fi
    fi

    cat > "$wrapper" <<EOF
#!/usr/bin/env bash
$TAG
exec flatpak run $app_id "\$@"
EOF

    chmod +x "$wrapper"
done
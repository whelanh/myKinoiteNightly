#!/usr/bin/env bash
# generate-base-manifest — Generate list of all files in /usr and base package list
# at image build time. Run at end of Containerfile via RUN command.
#
# excludepkgs in dnf.conf is built from /usr/share/rakuos/protected-packages.txt
# which is the union of:
#   - base image protected-packages.txt  (shipped by rakuos-base)
#   - DE-specific packages appended by each DE's post-build-overlay.sh
#
# Only explicitly installed packages belong in that file — not all their deps.
# This keeps the overlay able to upgrade most packages while protecting the
# DE shell, kernel, and other core components.
set -euo pipefail

MANIFEST_DIR="/usr/share/rakuos"
MANIFEST_FILE="$MANIFEST_DIR/base-manifest.txt"
BASE_PACKAGES_FILE="$MANIFEST_DIR/base-packages.txt"
PROTECTED_FILE="$MANIFEST_DIR/protected-packages.txt"
RAKUOS_DNF_CONF="$MANIFEST_DIR/dnf.conf"

mkdir -p "$MANIFEST_DIR"

if [[ ! -f "$PROTECTED_FILE" ]] || [[ ! -s "$PROTECTED_FILE" ]]; then
    echo "ERROR: $PROTECTED_FILE not found or empty — cannot generate manifest or dnf.conf."
    exit 1
fi

# Parse protected packages — strip comments, blanks, group entries (@foo)
mapfile -t PROTECTED_PKGS < <(
    grep -v '^\s*#' "$PROTECTED_FILE" \
    | grep -v '^\s*$' \
    | sed 's/\s*#.*//' \
    | tr -s ' \t' '\n' \
    | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
    | grep -v '^$' \
    | grep -v '^@'
)

echo "Generating RakuOS base package list (all installed, for reference)..."
rpm --dbpath /usr/lib/sysimage/rpm -qa --qf '%{NAME}.%{ARCH}\n' \
  | sort -u > "$BASE_PACKAGES_FILE"
PKG_TOTAL=$(wc -l < "$BASE_PACKAGES_FILE")
echo "Base package list: $PKG_TOTAL packages → $BASE_PACKAGES_FILE"

# Extract python package names (strip arch suffix) for manifest + exclude use
mapfile -t PYTHON_PKGS < <(
    grep -E '^python' "$BASE_PACKAGES_FILE" | sed 's/\.[^.]*$//' | sort -u \
    | grep -vx 'python3-dbus'
)
echo "Found ${#PYTHON_PKGS[@]} python packages to add to manifest and excludepkgs."

echo "Generating RakuOS base file manifest from ${#PROTECTED_PKGS[@]} protected + ${#PYTHON_PKGS[@]} python packages..."

# Build manifest from files owned by protected packages and all python packages.
# Silently skip packages not installed (e.g. a DE package not present in base).
{
    for pkg in "${PROTECTED_PKGS[@]}" "${PYTHON_PKGS[@]}"; do
        rpm --dbpath /usr/lib/sysimage/rpm -ql "$pkg" 2>/dev/null || true
    done
} | grep '^/usr/' | sort -u > "$MANIFEST_FILE"

TOTAL=$(wc -l < "$MANIFEST_FILE")
echo "Manifest generated: $TOTAL files → $MANIFEST_FILE"

echo "Writing RakuOS dnf config..."
# Merge protected packages with all python* packages from base-packages.txt.
# Python packages are excluded to prevent the overlay from partially overriding
# Python libs and causing import errors (e.g. broken encodings module).
EXCLUDE_LIST=$(
    { printf '%s\n' "${PROTECTED_PKGS[@]}"; printf '%s\n' "${PYTHON_PKGS[@]}"; } \
    | sort -u | paste -sd ',' -
)
printf '[main]\nkeepcache=True\nexcludepkgs=%s\n' "$EXCLUDE_LIST" > "$RAKUOS_DNF_CONF"
TOTAL_EXCLUDED=$(printf '%s\n' "$EXCLUDE_LIST" | tr ',' '\n' | grep -c .)
echo "RakuOS dnf config written → $RAKUOS_DNF_CONF ($TOTAL_EXCLUDED packages excluded, includes python* from base)"

echo "RakuOS base manifest generation complete."
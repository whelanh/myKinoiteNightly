#!/usr/bin/env bash
# rakuos-base-protect — Monitor overlay UPPER_DIR for shadowing of base /usr files.
# Runs as a daemon, blocks in inotifywait, removes shadowed files immediately
# and notifies the active user session.
set -euo pipefail

UPPER_DIR="/var/lib/rakuos/overlay/upper"
LOCK_FILE="/run/rakuos-overlay.lock"
LOG_TAG="rakuos-base-protect"
MANIFEST="/usr/share/rakuos/base-manifest.txt"
NOTIFY_PENDING="/run/rakuos-base-protect-pending"
NOTIFY_PID_FILE="/run/rakuos-base-protect-notify.pid"

# Path prefixes that are legitimately writable at runtime — never block these
EXCLUSION_PREFIXES=(
    "/usr/lib/sysimage/libdnf5"
    "/usr/share/rpm"
    "/usr/share/doc"
    "/usr/share/licenses"
    "/usr/lib/.build-id"
    "/usr/lib64/.build-id"
)

# Glob patterns for exclusions that require wildcard matching
EXCLUSION_GLOBS=(
    "/usr/lib/python*/__pycache__/*"
    "/usr/lib/python*/site-packages/*/__pycache__/*"
    "/usr/lib/python*/site-packages/*/*/__pycache__/*"
)


# Files in the base image that are intentionally writable at runtime
EXCLUSIONS=(
    "/usr/share/applications/mimeinfo.cache"
    "/usr/share/icons/hicolor/icon-theme.cache"
    "/usr/share/glib-2.0/schemas/gschemas.compiled"
    "/usr/share/rpm/rpmdb.sqlite"
    "/usr/share/rpm/rpmdb.sqlite-shm"
    "/usr/share/rpm/rpmdb.sqlite-wal"
    "/usr/share/rpm/.rpm.lock"
)

# ── Helpers ───────────────────────────────────────────────────────────────────

log() { echo "$LOG_TAG: $*"; }

notify_user() {
    local title="$1"
    local body="$2"
    local urgency="${3:-normal}"
    
    local active_user user_uid user_runtime
    active_user=$(loginctl list-sessions --no-legend 2>/dev/null \
    | awk '{print $3}' | head -n1)
    [[ -z "$active_user" ]] && return
    
    user_uid=$(id -u "$active_user" 2>/dev/null) || return
    user_runtime="/run/user/$user_uid"
    
    sudo -u "$active_user" \
    DBUS_SESSION_BUS_ADDRESS="unix:path=$user_runtime/bus" \
    notify-send \
    --app-name="RakuOS Base Protection" \
    --icon=security-high \
    --urgency="$urgency" \
    "$title" "$body" 2>/dev/null || true
}

# Schedule a single batched notification after a short debounce window
# Kills any pending notification timer and restarts it — fires once activity stops
schedule_notify() {
    # Append blocked path to pending list
    echo "$1" >> "$NOTIFY_PENDING"
    
    # Kill existing debounce timer if running
    if [[ -f "$NOTIFY_PID_FILE" ]]; then
        local old_pid
        old_pid=$(cat "$NOTIFY_PID_FILE" 2>/dev/null)
        kill "$old_pid" 2>/dev/null || true
        rm -f "$NOTIFY_PID_FILE"
    fi
    
    # Start new debounce timer — fires after 3s of no new events
    (
        echo $$ > "$NOTIFY_PID_FILE"
        sleep 3
        local count
        count=$(wc -l < "$NOTIFY_PENDING" 2>/dev/null || echo 0)
        local files
        files=$(sort -u "$NOTIFY_PENDING" 2>/dev/null | head -5 | tr '\n' '\n')
        rm -f "$NOTIFY_PENDING" "$NOTIFY_PID_FILE"
        
        if [[ "$count" -eq 1 ]]; then
            notify_user \
            "Base System Protection" \
            "A modification to a base system file was blocked:\n\n$files\n\nBase files are managed by bootc update." \
            "normal"
        else
            notify_user \
            "Base System Protection" \
            "$count modifications to base system files were blocked:\n\n$files\n\nBase files are managed by bootc update." \
            "normal"
        fi
    ) &
}

is_overlay_operation() {
    [[ -f "$LOCK_FILE" ]]
}

handle_event() {
    local event_dir="$1"
    local event_file="$2"
    
    local full_overlay_path="${event_dir}${event_file}"
    
    # Map overlay path → base /usr path
    local base_path="/usr${full_overlay_path#$UPPER_DIR}"
    
    # Only act if this path is exactly in the base image manifest
    grep -qxF "$base_path" "$MANIFEST" || return 0
    
    # Allow paths under excluded prefixes (RPM db, runtime writable dirs)
    for prefix in "${EXCLUSION_PREFIXES[@]}"; do
        [[ "$base_path" == "$prefix"* ]] && return 0
    done

    # Allow paths matching wildcard glob patterns (e.g. __pycache__ dirs)
    for glob in "${EXCLUSION_GLOBS[@]}"; do
        # shellcheck disable=SC2254
        case "$base_path" in $glob) return 0 ;; esac
    done
    
    # Allow explicitly excluded files that are legitimately writable at runtime
    for exclusion in "${EXCLUSIONS[@]}"; do
        [[ "$base_path" == "$exclusion" ]] && return 0
    done
    
    # Allow legitimate overlay operations
    if is_overlay_operation; then
        log "overlay operation in progress — allowing write to $base_path"
        return 0
    fi
    
    log "BLOCKED: shadow of base image file detected: $full_overlay_path"
    log "  Base path: $base_path"
    
    rm -rf "$full_overlay_path" 2>/dev/null \
    && log "  Removed shadow successfully." \
    || log "  WARNING: could not remove shadow at $full_overlay_path"
    
    schedule_notify "$base_path"
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v inotifywait &>/dev/null; then
    log "ERROR: inotifywait not found. Install inotify-tools package."
    exit 1
fi

if [[ ! -f "$MANIFEST" ]]; then
    log "ERROR: base manifest not found at $MANIFEST — protection cannot run."
    log "  Regenerate with: /usr/libexec/rakuos/generate-base-manifest"
    exit 1
fi

log "Loaded base manifest: $(wc -l < "$MANIFEST") files"

# Wait for overlay upper dir to be available
until [[ -d "$UPPER_DIR" ]]; do
    log "Waiting for overlay upper dir to be available..."
    sleep 2
done

log "Starting base protection watcher on $UPPER_DIR"

inotifywait \
--monitor \
--recursive \
--quiet \
--format '%w %f' \
--event create \
--event moved_to \
--event close_write \
"$UPPER_DIR" \
| while IFS=' ' read -r event_dir event_file; do
    handle_event "$event_dir" "$event_file"
done

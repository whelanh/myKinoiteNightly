#!/usr/bin/env bash
# rakuos-cache-clean — Prune stale and outdated RPMs from dnf and local-rpm caches.
#
# DNF cache (/var/cache/libdnf5):
#   - For each package name, keep only the newest version; remove older copies.
#   - Remove any remaining .rpm whose package is not installed in the overlay.
#
# Local-RPM cache (/var/lib/rakuos/local-rpms):
#   - Remove any .rpm (and its packages-rpm.list entry) whose package is not
#     installed in the overlay.
#   - Remove orphaned .rpm files in the cache not listed in packages-rpm.list.
#
# The overlay RPM database at $OVERLAY_RPM_DB is used as the installed-package
# reference.  It is a full db (base + overlay) maintained by rakuos-overlay-sync.
# If the db is absent the script exits cleanly — nothing to check against.

set -euo pipefail

DNF_CACHE_DIR="/var/cache/libdnf5"
LOCAL_RPM_CACHE="/var/lib/rakuos/local-rpms"
LOCAL_RPM_LIST="/var/lib/rakuos/packages-rpm.list"
OVERLAY_RPM_DB="/var/lib/rakuos/overlay/upper/share/rpm"

die() { echo "ERROR: $*" >&2; exit 1; }

# ── Pre-flight ────────────────────────────────────────────────────────────────

if [[ ! -d "$OVERLAY_RPM_DB" ]] || [[ -z "$(ls -A "$OVERLAY_RPM_DB" 2>/dev/null)" ]]; then
    echo "RakuOS cache clean: overlay RPM database not found or empty — nothing to check against, exiting."
    exit 0
fi

# ── DNF cache ─────────────────────────────────────────────────────────────────
_clean_dnf_cache() {
    [[ -d "$DNF_CACHE_DIR" ]] || return 0

    echo "RakuOS cache clean: scanning DNF cache at $DNF_CACHE_DIR ..."

    # Collect all .rpm files, reading name+EVR from each header.
    # Build: pkg_name -> newline-separated list of "EVR<TAB>filepath" (unsorted).
    declare -A pkg_entries=()

    while IFS= read -r rpm_file; do
        local info
        info=$(rpm -qp --qf '%{NAME}\t%{ARCH}\t%{EPOCH}:%{VERSION}-%{RELEASE}' "$rpm_file" 2>/dev/null) || continue
        local pkg_name pkg_arch pkg_evr
        pkg_name=$(echo "$info" | cut -f1)
        pkg_arch=$(echo "$info"  | cut -f2)
        pkg_evr=$(echo "$info"   | cut -f3)
        [[ -z "$pkg_name" || -z "$pkg_arch" || -z "$pkg_evr" ]] && continue
        # Key by NAME.ARCH so foo.i686 and foo.x86_64 are treated as separate packages.
        local pkg_key="${pkg_name}.${pkg_arch}"
        pkg_entries["$pkg_key"]+="${pkg_evr}"$'\t'"${rpm_file}"$'\n'
    done < <(find "$DNF_CACHE_DIR" -name "*.rpm" -type f 2>/dev/null)

    local removed_old=0 removed_uninstalled=0

    for pkg_key in "${!pkg_entries[@]}"; do
        # Split key back into name and arch.
        local pkg_name="${pkg_key%.*}"
        local pkg_arch="${pkg_key##*.}"

        # Sort entries by EVR descending (newest first).
        # Each line: "EVR<TAB>filepath"
        mapfile -t sorted < <(
            printf '%s' "${pkg_entries[$pkg_key]}" \
            | grep -v '^$' \
            | sort -t$'\t' -k1 -V -r
        )

        [[ ${#sorted[@]} -eq 0 ]] && continue

        local newest_file
        newest_file=$(printf '%s' "${sorted[0]}" | cut -f2)

        # Remove older versions (all but the first/newest entry).
        local i
        for (( i=1; i<${#sorted[@]}; i++ )); do
            local old_file
            old_file=$(printf '%s' "${sorted[$i]}" | cut -f2)
            echo "  Removing old version: $(basename "$old_file") ($pkg_key)"
            rm -f "$old_file"
            (( removed_old++ )) || true
        done

        # Remove newest if the package (this specific arch) is no longer installed in the overlay.
        if ! rpm --dbpath "$OVERLAY_RPM_DB" -q "${pkg_name}.${pkg_arch}" &>/dev/null; then
            echo "  Removing uninstalled: $(basename "$newest_file") ($pkg_key not in overlay)"
            rm -f "$newest_file"
            (( removed_uninstalled++ )) || true
        fi
    done

    # Remove empty directories left behind in the dnf cache.
    find "$DNF_CACHE_DIR" -mindepth 1 -type d -empty -delete 2>/dev/null || true

    echo "RakuOS cache clean: DNF cache — removed $removed_old old version(s), $removed_uninstalled uninstalled package(s)."
}

# ── Local-RPM cache ───────────────────────────────────────────────────────────
_clean_local_cache() {
    [[ -d "$LOCAL_RPM_CACHE" ]] || return 0

    echo "RakuOS cache clean: scanning local-RPM cache at $LOCAL_RPM_CACHE ..."

    local removed_uninstalled=0 removed_orphaned=0

    # Process packages-rpm.list: remove entries (and their .rpms) that are no
    # longer installed in the overlay.
    if [[ -f "$LOCAL_RPM_LIST" ]] && [[ -s "$LOCAL_RPM_LIST" ]]; then
        local tmp_list
        tmp_list=$(mktemp)

        while IFS= read -r pkg_name; do
            [[ -z "$pkg_name" ]] && continue
            if rpm --dbpath "$OVERLAY_RPM_DB" -q "$pkg_name" &>/dev/null; then
                # Still installed — keep list entry and cached file.
                echo "$pkg_name" >> "$tmp_list"
            else
                echo "  Removing uninstalled local RPM: $pkg_name"
                rm -f "$LOCAL_RPM_CACHE/${pkg_name}.rpm"
                (( removed_uninstalled++ )) || true
                # Entry intentionally not written to tmp_list — drops from list.
            fi
        done < "$LOCAL_RPM_LIST"

        mv "$tmp_list" "$LOCAL_RPM_LIST"
        chmod 644 "$LOCAL_RPM_LIST" || true
    fi

    # Remove any .rpm files in the cache directory that are not tracked in
    # packages-rpm.list (orphaned files from manual edits or old logic).
    while IFS= read -r rpm_file; do
        local pkg_name
        pkg_name=$(rpm -qp --qf '%{NAME}' "$rpm_file" 2>/dev/null) || continue
        if [[ -f "$LOCAL_RPM_LIST" ]] && grep -qx "$pkg_name" "$LOCAL_RPM_LIST" 2>/dev/null; then
            continue  # tracked and still installed
        fi
        echo "  Removing orphaned local RPM: $(basename "$rpm_file")"
        rm -f "$rpm_file"
        (( removed_orphaned++ )) || true
    done < <(find "$LOCAL_RPM_CACHE" -name "*.rpm" -type f 2>/dev/null)

    echo "RakuOS cache clean: local cache — removed $removed_uninstalled uninstalled, $removed_orphaned orphaned RPM(s)."
}

# ── Run ───────────────────────────────────────────────────────────────────────
_clean_dnf_cache
_clean_local_cache

echo "RakuOS cache clean: done."

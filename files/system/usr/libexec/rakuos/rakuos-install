#!/usr/bin/env bash
set -euo pipefail

PACKAGES=("${@}")
PACKAGES_LIST="/var/lib/rakuos/packages.list"
LOCAL_RPM_LIST="/var/lib/rakuos/packages-rpm.list"
LOCAL_RPM_CACHE="/var/lib/rakuos/local-rpms"
UPPER_DIR="/var/lib/rakuos/overlay/upper"
WORK_DIR="/var/lib/rakuos/overlay/work"
DIRTY_FILE="/var/lib/rakuos/overlay.dirty"
PKG_CACHE_DIR="/var/cache/libdnf5"
OVERLAY_RPM_DB="$UPPER_DIR/share/rpm"
BASE_RPM_DB_SNAPSHOT="/var/lib/rakuos/base-rpmdb"
BASE_PACKAGES_FILE="/usr/share/rakuos/base-packages.txt"
MODIFIED_BASE_LIST="/var/lib/rakuos/overlay-modified-base.list"

# Rebuild the modified-base tracking list by scanning the overlay RPM db.
# Checks every installed package (including dependencies pulled in by this
# install) against base-packages.txt — if any are newer than the base
# snapshot they get tracked for handback on the next image update.
_update_modified_base_list() {
    [[ -d "$OVERLAY_RPM_DB" ]] || return 0
    [[ -d "$BASE_RPM_DB_SNAPSHOT" ]] || return 0
    [[ -f "$BASE_PACKAGES_FILE" ]] || return 0
    local tmp_list
    tmp_list=$(mktemp)
    while IFS=' ' read -r pkg_name ovl_evr; do
        [[ -z "$pkg_name" ]] && continue
        grep -qx "$pkg_name" "$BASE_PACKAGES_FILE" 2>/dev/null || continue
        local base_evr
        base_evr=$(rpm --dbpath "$BASE_RPM_DB_SNAPSHOT" -q "$pkg_name" \
            --qf '%{EPOCH}:%{VERSION}-%{RELEASE}' 2>/dev/null) || true
        [[ -z "$base_evr" ]] && continue
        local base_ver ovl_ver
        base_ver="${base_evr#0:}"
        ovl_ver="${ovl_evr#0:}"
        [[ "$base_ver" == "$ovl_ver" ]] && continue
        local newer
        newer=$(printf '%s\n%s\n' "$base_ver" "$ovl_ver" | sort -V | tail -1)
        [[ "$newer" == "$ovl_ver" ]] && echo "$pkg_name" >> "$tmp_list" || true
    done < <(rpm --dbpath "$OVERLAY_RPM_DB" -qa \
        --qf '%{NAME} %{EPOCH}:%{VERSION}-%{RELEASE}\n' 2>/dev/null)
    sort -u "$tmp_list" > "$MODIFIED_BASE_LIST"
    rm -f "$tmp_list"
}

if [[ "${#PACKAGES[@]}" -eq 0 ]]; then
    echo "Usage: rakuos install <package> [package2] [package3]..."
    exit 1
fi

# Must run as root
if [[ "$EUID" -ne 0 ]]; then
    echo "ERROR: rakuos install must be run as root"
    exit 1
fi

# Detect live environment — root is already a writable dmsquash-live overlay.
# Skip the overlay mount; list tracking and install still run normally.
IS_LIVE=false
if grep -q 'rd\.live\.image\|live\|liveimg' /proc/cmdline 2>/dev/null || \
   [[ -e /run/initramfs/livedev ]]; then
    IS_LIVE=true
fi

# Acquire lock so rakuos-base-protect allows our overlay writes
LOCK_FILE="/run/rakuos-overlay.lock"
touch "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# Ensure dirs exist
mkdir -p /var/lib/rakuos "$UPPER_DIR" "$WORK_DIR" "$LOCAL_RPM_CACHE"

# ── Normalise arguments ───────────────────────────────────────────────────────
# Pass all args to dnf as-is, but for packages.list:
#   - strip flags (e.g. -y, --assumeyes)
#   - for .rpm file paths, extract the actual package Name

CLEAN_ARGS=("${PACKAGES[@]}")  # dnf gets everything as passed
PKG_NAMES=()                   # packages.list gets only clean names
declare -A RPM_FILE_FOR=()     # pkg_name -> original .rpm file path (local RPMs only)

for arg in "${PACKAGES[@]}"; do
    # Skip flags
    [[ "$arg" == -* ]] && continue
    # Local .rpm file — extract Name field and record the source path
    if [[ "$arg" == *.rpm ]]; then
        pkg_name=$(rpm -qp --queryformat '%{NAME}' "$arg" 2>/dev/null)
        if [[ -z "$pkg_name" ]]; then
            echo "WARNING: could not read package name from $arg — skipping list entry"
            continue
        fi
        PKG_NAMES+=("$pkg_name")
        RPM_FILE_FOR["$pkg_name"]="$arg"
    else
        PKG_NAMES+=("$arg")
    fi
done

# Filter out already installed packages (by clean name only)
# Also block packages owned by the base image
BASE_PKGS=""
if [[ -f "$BASE_PACKAGES_FILE" ]]; then
    BASE_PKGS=$(cat "$BASE_PACKAGES_FILE")
fi

TO_INSTALL_ARGS=("${CLEAN_ARGS[@]}")  # dnf args unchanged
TO_INSTALL_NAMES=()
for pkg in "${PKG_NAMES[@]}"; do
    # Block base image packages — bootc owns these
    if [[ -n "$BASE_PKGS" ]] && echo "$BASE_PKGS" | grep -qx "$pkg"; then
        echo "INFO: $pkg is part of the base system image and cannot be managed via the overlay."
        echo "      Use 'bootc update' to update base image packages."
        continue
    fi
    if grep -qx "$pkg" "$PACKAGES_LIST" 2>/dev/null; then
        echo "$pkg is already installed via RakuOS overlay — skipping."
    else
        TO_INSTALL_NAMES+=("$pkg")
    fi
done

if [[ "${#TO_INSTALL_NAMES[@]}" -eq 0 ]]; then
    echo "All requested packages already installed."
    exit 0
fi

echo "Installing ${TO_INSTALL_NAMES[*]} via RakuOS overlay..."

# Mount our persistent overlay if not already active (skip on live — root already writable)
if [[ "$IS_LIVE" != "true" ]] && ! findmnt /usr | grep -q overlay; then
    echo "Mounting RakuOS overlay..."
    mount -t overlay overlay \
        -o lowerdir=/usr,upperdir="$UPPER_DIR",workdir="$WORK_DIR" \
        /usr
fi

# Install into overlay — excludes base packages from dep resolution
dnf5.real install -y --refresh --config="/usr/share/rakuos/dnf.conf" \
    "${TO_INSTALL_ARGS[@]}"

# Mark newly installed packages as user so PackageKit can manage them
for pkg in "${TO_INSTALL_NAMES[@]}"; do
    dnf5.real -y mark user "$pkg" || true
done

# Write installed packages to the appropriate list:
#   - Local .rpm installs → packages-rpm.list + cache the file
#   - Repo installs       → packages.list
if [[ -s "$PACKAGES_LIST" ]]; then
    tail -c1 "$PACKAGES_LIST" | grep -qx '' || echo "" >> "$PACKAGES_LIST"
fi
for pkg in "${TO_INSTALL_NAMES[@]}"; do
    if [[ -n "${RPM_FILE_FOR[$pkg]:-}" ]]; then
        # Cache the RPM file and track in packages-rpm.list
        cp "${RPM_FILE_FOR[$pkg]}" "$LOCAL_RPM_CACHE/${pkg}.rpm"
        grep -qx "$pkg" "$LOCAL_RPM_LIST" 2>/dev/null || echo "$pkg" >> "$LOCAL_RPM_LIST"
        chmod 644 "$LOCAL_RPM_LIST" || true
    else
        echo "$pkg" >> "$PACKAGES_LIST"
    fi
done

# Save current digest to state file if not already set
if [[ ! -f "/var/lib/rakuos/overlay.state" ]]; then
    bootc status --json | jq -r '.status.booted.image.imageDigest // empty' > /var/lib/rakuos/overlay.state
fi

# Set dirty flag so boot service syncs on next boot
touch "$DIRTY_FILE"

# Rebuild the modified-base tracking list — must run last so the overlay RPM db
# reflects the completed install. Scans all overlay packages (including deps
# pulled in by this install) against base-packages.txt.
_update_modified_base_list

echo "${TO_INSTALL_NAMES[*]} installed successfully and added to RakuOS package list."

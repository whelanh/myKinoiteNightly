#!/usr/bin/env bash
# rakuos-migrate — Migrate from overlayfs package management to installroot.
#
# Detects whether an existing system has packages installed via the old overlay
# approach and reinstalls them all into the new installroot at
# /var/lib/rakuos/packages.  Safe to run multiple times — exits immediately
# if the installroot is already populated or no packages are present.
#
# Called automatically by rakuos-migrate.service on first boot of a new image
# that ships the installroot approach.  Can also be run manually by the user.
set -euo pipefail

INSTALLROOT="/var/lib/rakuos/packages"
PKGROOT_TRACK="/var/lib/rakuos/pkgroot-packages.txt"
PKG_CACHE_DIR="/var/cache/libdnf5"
PACKAGES_LIST="/var/lib/rakuos/packages.list"
OLD_UPPER_DIR="/var/lib/rakuos/overlay/upper"
STATE_FILE="/var/lib/rakuos/overlay.state"
DIRTY_FILE="/var/lib/rakuos/overlay.dirty"
MIGRATE_DONE="/var/lib/rakuos/migration-installroot.done"

FEDORA_VER=$(. /etc/os-release && echo "$VERSION_ID")

# ── Helpers ───────────────────────────────────────────────────────────────────

log() { echo "RakuOS migrate: $*"; }
die() { echo "RakuOS migrate ERROR: $*" >&2; exit 1; }

_dnf() {
    dnf5.real --installroot "$INSTALLROOT" \
              --setopt=reposdir=/etc/yum.repos.d \
              --releasever "$FEDORA_VER" \
              --setopt=best=False \
              --setopt=keepcache=True \
              "$@"
}

_installroot_ready() {
    local rpm_db="$INSTALLROOT/usr/share/rpm"
    [[ -d "$rpm_db" ]] && [[ -n "$(ls -A "$rpm_db" 2>/dev/null)" ]]
}

# ── Guard: skip if already done ───────────────────────────────────────────────

if [[ -f "$MIGRATE_DONE" ]]; then
    log "Already migrated (found $MIGRATE_DONE) — nothing to do."
    exit 0
fi

if _installroot_ready; then
    log "Installroot already populated — ensuring tracking and state are current..."
    # Write tracking if missing so image-update merges work correctly
    if [[ ! -s "$PKGROOT_TRACK" ]]; then
        mkdir -p /var/lib/rakuos
        comm -23 \
            <(rpm --root "$INSTALLROOT" -qa --qf '%{NAME}\n' 2>/dev/null | sort -u) \
            <(rpm --dbpath /usr/share/rpm  -qa --qf '%{NAME}\n' 2>/dev/null | sort -u) \
            > "$PKGROOT_TRACK" 2>/dev/null || true
        log "Tracking file written ($(wc -l < "$PKGROOT_TRACK") packages)."
    fi
    # Write state digest if missing
    if [[ ! -f "$STATE_FILE" ]]; then
        bootc status --json \
            | jq -r '.status.booted.image.imageDigest // empty' 2>/dev/null \
            > "$STATE_FILE" || echo "unknown" > "$STATE_FILE"
    fi
    touch "$MIGRATE_DONE"
    exit 0
fi

# ── Guard: nothing to migrate ─────────────────────────────────────────────────

if [[ ! -f "$PACKAGES_LIST" ]] || [[ ! -s "$PACKAGES_LIST" ]]; then
    log "No packages.list found or it is empty — nothing to migrate."
    touch "$MIGRATE_DONE"
    exit 0
fi

# Read packages, strip comments and blanks
mapfile -t PACKAGES < <(
    grep -v '^\s*#' "$PACKAGES_LIST" \
    | grep -v '^\s*$' \
    | sed 's/\s*#.*//' \
    | tr -s ' \t' '\n' \
    | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
    | grep -v '^$'
)

if [[ "${#PACKAGES[@]}" -eq 0 ]]; then
    log "packages.list has no installable entries — nothing to migrate."
    touch "$MIGRATE_DONE"
    exit 0
fi

log "Detected ${#PACKAGES[@]} package(s) to migrate: ${PACKAGES[*]}"

# ── Detect old overlay ────────────────────────────────────────────────────────

OLD_OVERLAY_ACTIVE=false
if findmnt /usr 2>/dev/null | grep -q overlay; then
    OLD_OVERLAY_ACTIVE=true
    log "Old overlayfs is currently mounted on /usr — will install alongside it."
    log "Old overlay dirs will be cleaned up after reboot."
fi

# ── Init installroot RPM db ───────────────────────────────────────────────────

log "Seeding installroot RPM database from base image (/usr/share/rpm)..."
mkdir -p "$INSTALLROOT/usr/share/rpm"
cp -a /usr/share/rpm/. "$INSTALLROOT/usr/share/rpm/"
mkdir -p "$INSTALLROOT/usr/lib/sysimage"
ln -sfn ../../share/rpm "$INSTALLROOT/usr/lib/sysimage/rpm"
log "Installroot RPM db seeded."

# Import Terra GPG keys if not already present in the image db
log "Importing Terra GPG keys..."
rpm --root "$INSTALLROOT" --import \
    "https://repos.fyralabs.com/terra${FEDORA_VER}/key.asc" 2>/dev/null || true
rpm --root "$INSTALLROOT" --import \
    "https://repos.fyralabs.com/terra${FEDORA_VER}-mesa/key.asc" 2>/dev/null || true
rpm --root "$INSTALLROOT" --import \
    "https://repos.fyralabs.com/terra${FEDORA_VER}-multimedia/key.asc" 2>/dev/null || true

# ── Remove stale old-overlay service symlinks ────────────────────────────────
# The old service names were enabled on the running system; their unit files no
# longer exist in the new image.  Remove the dangling wants symlinks so systemd
# doesn't log warnings about them on every boot.
for stale in \
    rakuos-overlay-mount.service \
    rakuos-overlay-sync.service \
    rakuos-overlay-services.service \
    rakuos-base-protect.service; do
    for wants_dir in \
        /etc/systemd/system/multi-user.target.wants \
        /etc/systemd/system/sysinit.target.wants \
        /etc/systemd/system/graphical.target.wants; do
        [[ -L "$wants_dir/$stale" ]] && rm -f "$wants_dir/$stale" && \
            log "Removed stale symlink: $wants_dir/$stale"
    done
done

# ── Install packages ──────────────────────────────────────────────────────────

log "Installing packages into installroot (this may take a while)..."
_dnf install -y --refresh "${PACKAGES[@]}" \
    || die "Package installation failed. Check the journal for details."

# Mark all as user-installed
for pkg in "${PACKAGES[@]}"; do
    _dnf mark user "$pkg" 2>/dev/null || true
done

# Record user packages + deps in installroot tracking file
log "Updating installroot package tracking..."
mkdir -p /var/lib/rakuos
comm -23 \
    <(rpm --root "$INSTALLROOT" -qa --qf '%{NAME}\n' 2>/dev/null | sort -u) \
    <(rpm --dbpath /usr/share/rpm  -qa --qf '%{NAME}\n' 2>/dev/null | sort -u) \
    > "$PKGROOT_TRACK" 2>/dev/null || true

# ── Fix hardcoded /usr/ paths in installroot .desktop files ──────────────────
_fix_desktop_exec_paths() {
    local app_dir="$INSTALLROOT/usr/share/applications"
    [[ -d "$app_dir" ]] || return 0
    local count=0
    local tmpfile
    while IFS= read -r -d '' desktop; do
        local changed=false
        tmpfile=$(mktemp)
        while IFS= read -r line; do
            if [[ "$line" =~ ^(Exec=|TryExec=)(.*) ]]; then
                local key="${BASH_REMATCH[1]}" val="${BASH_REMATCH[2]}"
                local mods=""
                if [[ "$val" =~ ^([-@!+]+)(.*) ]]; then
                    mods="${BASH_REMATCH[1]}"; val="${BASH_REMATCH[2]}"
                fi
                local first_token="${val%% *}"
                if [[ "$first_token" == /usr/* ]]; then
                    local ir_bin="${INSTALLROOT}${first_token}"
                    if [[ -f "$ir_bin" || -L "$ir_bin" ]]; then
                        local rest="${val#"$first_token"}"
                        line="${key}${mods}${INSTALLROOT}${first_token}${rest}"
                        changed=true
                    fi
                fi
            fi
            printf '%s\n' "$line"
        done < "$desktop" > "$tmpfile"
        if [[ "$changed" == "true" ]]; then
            mv "$tmpfile" "$desktop"
            (( count++ )) || true
        else
            rm -f "$tmpfile"
        fi
    done < <(find "$app_dir" -name "*.desktop" -print0 2>/dev/null)
    [[ $count -gt 0 ]] && log "Fixed Exec= paths in $count desktop file(s)."
    return 0
}

# ── Post-install integration ──────────────────────────────────────────────────

log "Updating linker cache and desktop database..."
ldconfig
systemctl daemon-reload 2>/dev/null || true
if [[ -d "$INSTALLROOT/usr/share/applications" ]]; then
    _fix_desktop_exec_paths
    update-desktop-database "$INSTALLROOT/usr/share/applications" 2>/dev/null || true
fi
if [[ -d "$INSTALLROOT/usr/share/icons/hicolor" ]]; then
    gtk-update-icon-cache -f -t "$INSTALLROOT/usr/share/icons/hicolor" 2>/dev/null || true
fi

# ── Update state ──────────────────────────────────────────────────────────────

CURRENT_DIGEST=$(bootc status --json \
    | jq -r '.status.booted.image.imageDigest // empty' 2>/dev/null || echo "unknown")
echo "$CURRENT_DIGEST" > "$STATE_FILE"
rm -f "$DIRTY_FILE"

# ── Schedule old overlay cleanup on next boot ─────────────────────────────────

if [[ "$OLD_OVERLAY_ACTIVE" == "true" ]] \
    || [[ -d "$OLD_UPPER_DIR" && -n "$(ls -A "$OLD_UPPER_DIR" 2>/dev/null)" ]]; then
    log "Scheduling old overlay directory cleanup on next reboot..."
    cat > /var/lib/rakuos/cleanup-overlay.sh << 'CLEANUP'
#!/usr/bin/env bash
# One-shot cleanup of old overlayfs dirs after migration to installroot.
OLD_UPPER="/var/lib/rakuos/overlay/upper"
OLD_WORK="/var/lib/rakuos/overlay/work"
rm -rf "$OLD_UPPER" "$OLD_WORK"
rm -f /var/lib/rakuos/image-packages.toml
rm -f /var/lib/rakuos/base-rpmdb
rm -f /var/lib/rakuos/cleanup-overlay.sh
# Disable the cleanup service so it doesn't run again
systemctl disable rakuos-pkgroot-cleanup.service 2>/dev/null || true
echo "RakuOS: old overlay dirs cleaned up."
CLEANUP
    chmod +x /var/lib/rakuos/cleanup-overlay.sh
    # Activate the cleanup service if systemd is running
    systemctl enable rakuos-pkgroot-cleanup.service 2>/dev/null || true
fi

# ── Done ──────────────────────────────────────────────────────────────────────

touch "$MIGRATE_DONE"
log "Migration complete. ${#PACKAGES[@]} package(s) installed into installroot."
if [[ "$OLD_OVERLAY_ACTIVE" == "true" ]]; then
    log "Reboot to complete transition — old overlay will be removed on next boot."
fi

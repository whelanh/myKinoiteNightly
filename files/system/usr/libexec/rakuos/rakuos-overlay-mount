#!/usr/bin/env bash
set -euo pipefail

UPPER_DIR="/var/lib/rakuos/overlay/upper"
WORK_DIR="/var/lib/rakuos/overlay/work"
STATE_FILE="/var/lib/rakuos/overlay.state"
PACKAGES_LIST="/var/lib/rakuos/packages.list"
DEFAULT_PACKAGES_LIST="/usr/share/rakuos/packages.list"
LIVE_PACKAGES_LIST="/usr/share/rakuos/packages-live.list"
RESET_MARKER="/var/lib/rakuos/overlay.reset"
DIRTY_FILE="/var/lib/rakuos/overlay.dirty"
PKGCACHE_MIGRATED="/var/lib/rakuos/pkgcache.migrated"
OS_VERSION_FILE="/var/lib/rakuos/os-version"

# Tracks whether this run is doing initial packages.list seeding (first boot / post-reset).
# If true, setup-complete is NOT created — the initial-setup wizard needs to run.
IS_INITIAL_SEED=false

# ── Live environment — suppress initial-setup, seed live package list ─────────
# On a live ISO the overlay is ephemeral; touch setup-complete immediately so the
# initial-setup wizard does not start.  If packages-live.list exists it is used
# as packages.list for the session so the overlay installs the live-specific set
# of packages rather than the normal installed-system set.
if grep -q 'rd\.live\.image\|live\|liveimg' /proc/cmdline 2>/dev/null || \
   [[ -e /run/initramfs/livedev ]]; then
    echo "RakuOS overlay: live environment detected — suppressing initial-setup."
    mkdir -p /var/lib/rakuos
    touch /var/lib/rakuos/setup-complete

    mkdir -p "$(dirname "$PACKAGES_LIST")"
    if [[ -f "$LIVE_PACKAGES_LIST" ]]; then
        echo "RakuOS overlay: seeding packages.list from packages-live.list for live session."
        cp "$LIVE_PACKAGES_LIST" "$PACKAGES_LIST"
    elif [[ -f "$DEFAULT_PACKAGES_LIST" ]]; then
        echo "RakuOS overlay: no packages-live.list — falling back to default packages.list."
        cp "$DEFAULT_PACKAGES_LIST" "$PACKAGES_LIST"
    else
        : > "$PACKAGES_LIST"
    fi
    sed -i -e '$a\' "$PACKAGES_LIST"
    touch "$DIRTY_FILE"

    # The live root is already a writable overlay managed by dmsquash-live
    # (squashfs lower + tmpfs upper). Stacking another overlayfs on /usr on top
    # of that fails with "not supported as upperdir". Skip the mount entirely —
    # the live root is already writable.
    echo "RakuOS overlay: live environment — skipping /usr overlay mount."
    exit 0
fi

# ── OS upgrade soft reset trigger ─────────────────────────────────────────────
if [[ -f "$OS_VERSION_FILE" && -f /etc/os-release ]]; then

    . /etc/os-release
    CURRENT_VERSION="${VERSION_ID:-unknown}"
    SAVED_VERSION="$(cat "$OS_VERSION_FILE" 2>/dev/null || echo unknown)"

    echo "RakuOS overlay: version check — saved=$SAVED_VERSION current=$CURRENT_VERSION"

    if [[ "$SAVED_VERSION" != "unknown" ]] && [[ "$CURRENT_VERSION" != "unknown" ]]; then
        if [[ "$CURRENT_VERSION" != "$SAVED_VERSION" ]]; then
            echo "RakuOS overlay: version change detected — triggering soft reset (dnf cache wipe)"
            rm -f "$PKGCACHE_MIGRATED"
            rm -rf /var/cache/libdnf5
        fi
    fi

fi

# ── Reset requested on last boot ──────────────────────────────────────────────
if [[ -f "$RESET_MARKER" ]]; then
    echo "RakuOS overlay: reset marker found — wiping overlay..."
    # Wipe overlay dirs
    rm -rf "${UPPER_DIR:?}"/*
    rm -rf "${WORK_DIR:?}"/*

    # Clear state files
    rm -f "$STATE_FILE"
    rm -f "$PACKAGES_LIST"

    # Reset RPM database to base image state
    echo "RakuOS overlay: resetting RPM database to base image state..."
    #rm -rf /var/lib/rpm/
    #rsync -a --delete /usr/share/rpm/ /var/lib/rpm/

    # Remove marker — reset complete
    rm -f "$RESET_MARKER"

    echo "RakuOS overlay: reset complete. Starting with clean base."
    # Fall through — seed packages.list and let sync handle install on next step
fi

# ── Seed packages.list from image default if missing ─────────────────────────
# This covers first boot on a fresh install and post-reset.
# The sync step reads this file to know what to install into the overlay.
mkdir -p "$(dirname "$PACKAGES_LIST")"

if [[ ! -f "$PACKAGES_LIST" ]]; then
    IS_INITIAL_SEED=true
    if [[ -f "$DEFAULT_PACKAGES_LIST" ]]; then
        echo "RakuOS overlay: seeding packages.list from $DEFAULT_PACKAGES_LIST ..."
        cp "$DEFAULT_PACKAGES_LIST" "$PACKAGES_LIST"
        # Ensure packages.list ends with newline
        sed -i -e '$a\' "$PACKAGES_LIST"
        # Mark dirty so sync installs the seeded packages into the overlay
        touch "$DIRTY_FILE"
        echo "RakuOS overlay: dirty file created — sync will install seeded packages."
    else
        echo "RakuOS overlay: no default packages.list found at $DEFAULT_PACKAGES_LIST — starting empty."
        touch "$PACKAGES_LIST"
        # Ensure packages.list ends with newline
        sed -i -e '$a\' "$PACKAGES_LIST"
    fi
fi

# ── Always snapshot the base image state ─────────────────────────────────────
# Done unconditionally so resets and migrations have a fresh snapshot available
# before sync runs, not just when the upper dir already has content.
mkdir -p "$UPPER_DIR" "$WORK_DIR"

IMAGE_PKGS_SRC="/usr/lib/sysimage/libdnf5/packages.toml"
IMAGE_PKGS_SAVE="/var/lib/rakuos/image-packages.toml"
if [[ -f "$IMAGE_PKGS_SRC" ]]; then
    cp "$IMAGE_PKGS_SRC" "$IMAGE_PKGS_SAVE"
fi

BASE_RPM_DB=/usr/share/rpm
SNAPSHOT_DB=/var/lib/rakuos/base-rpmdb

mkdir -p "$SNAPSHOT_DB"
cp -a "$BASE_RPM_DB/." "$SNAPSHOT_DB/"
# Drop stale lock and Berkeley DB cache files — process-specific and will cause
# "can't create transaction lock" errors if carried into a fresh overlay RPM db.
rm -f "$SNAPSHOT_DB"/.rpm.lock "$SNAPSHOT_DB"/__db.*

# ── One-time migration: pre-pkgcache overlay ─────────────────────────────────
# Systems that predate the pkgcache setup won't have pkgcache.migrated.
# Wipe the overlay once so sync does a clean reinstall with the new cache setup.
# packages.list is preserved so all user packages are reinstalled transparently.
if [[ -n "$(ls -A "$UPPER_DIR" 2>/dev/null)" ]] && [[ ! -f "$PKGCACHE_MIGRATED" ]]; then
    echo "RakuOS overlay: pkgcache migration — wiping overlay for clean reinstall..."
    rm -rf "${UPPER_DIR:?}"/*
    rm -rf "${WORK_DIR:?}"/*
    rm -f "$STATE_FILE"
    echo "RakuOS overlay: wipe complete — seeding RPM database before overlay mounts..."
    mkdir -p "$UPPER_DIR/share/rpm"
    cp -a "$SNAPSHOT_DB/." "$UPPER_DIR/share/rpm/"
    rm -f "$UPPER_DIR/share/rpm"/.rpm.lock "$UPPER_DIR/share/rpm"/__db.*
    touch "$PKGCACHE_MIGRATED"
    echo "RakuOS overlay: RPM database seeded — sync will reinstall packages on next step."
    exit 0
fi

# ── Normal mount ──────────────────────────────────────────────────────────────

# Already mounted — nothing to do
if findmnt /usr | grep -q overlay; then
    echo "RakuOS overlay: already mounted."
    exit 0
fi

# Upper dir empty (first boot, post-reset, post-migration) — pre-seed the RPM
# database into the upper dir now so it is ready before the overlay mounts.
# sync will install packages; it can skip re-seeding since the db is already here.
if [[ -z "$(ls -A "$UPPER_DIR" 2>/dev/null)" ]]; then
    echo "RakuOS overlay: seeding RPM database into upper dir before first install..."
    mkdir -p "$UPPER_DIR/share/rpm"
    cp -a "$SNAPSHOT_DB/." "$UPPER_DIR/share/rpm/"
    rm -f "$UPPER_DIR/share/rpm"/.rpm.lock "$UPPER_DIR/share/rpm"/__db.*
    touch "$PKGCACHE_MIGRATED"
    echo "RakuOS overlay: RPM database seeded — skipping mount, sync will handle install."
    exit 0
fi

OVERLAY_RPM_DB="$UPPER_DIR/share/rpm"
PRE_UPDATE_RPMDB="/var/lib/rakuos/pre-update-overlay-rpmdb"

# Back up the overlay RPM database before the overlay mounts.
# This snapshot reflects exactly what was installed in the overlay at the last boot.
# The image-update merge in rakuos-overlay-sync uses it to distinguish packages that
# are in the dnf/local RPM cache but were actually uninstalled by the user — those
# should not be re-registered into the rebuilt RPM database.
if [[ -d "$OVERLAY_RPM_DB" ]] && [[ -n "$(ls -A "$OVERLAY_RPM_DB" 2>/dev/null)" ]]; then
    echo "RakuOS overlay: backing up overlay RPM database before mount..."
    rm -rf "$PRE_UPDATE_RPMDB"
    mkdir -p "$PRE_UPDATE_RPMDB"
    cp -a "$OVERLAY_RPM_DB/." "$PRE_UPDATE_RPMDB/"
    rm -f "$PRE_UPDATE_RPMDB"/.rpm.lock "$PRE_UPDATE_RPMDB"/__db.*
    echo "RakuOS overlay: overlay RPM database backed up to $PRE_UPDATE_RPMDB."
fi

echo "RakuOS overlay: mounting persistent overlay..."
mount -t overlay overlay \
    -o lowerdir=/usr,upperdir="$UPPER_DIR",workdir="$WORK_DIR" \
    /usr

echo "RakuOS overlay: mounted."

# Always mark setup as complete, including on initial seed.
# TODO: restore the IS_INITIAL_SEED guard once rakuos-initial-setup ships:
#   if [[ "$IS_INITIAL_SEED" == "true" ]] || [[ -f "/var/lib/rakuos/setup-complete" ]]; then
touch /var/lib/rakuos/setup-complete

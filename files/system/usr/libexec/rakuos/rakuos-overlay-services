#!/usr/bin/env bash
# rakuos-overlay-services — Start systemd services installed via overlay packages.
# Runs after display-manager.service (SDDM/GDM) so session-dependent services work.
set -euo pipefail

UPPER_DIR="/var/lib/rakuos/overlay/upper"
SERVICE_DIR="$UPPER_DIR/lib/systemd/system"

if [[ ! -d "$SERVICE_DIR" ]]; then
    echo "RakuOS overlay services: no overlay service directory found, nothing to do."
    exit 0
fi

echo "Reload udev..."
udevadm control --reload-rules && udevadm trigger

echo "RakuOS overlay services: running daemon-reload..."
systemctl daemon-reload

echo "RakuOS overlay services: scanning for enabled overlay services..."
while IFS= read -r -d '' service_file; do
    service=$(basename "$service_file")

    # Skip template units
    [[ "$service" == *@* ]] && continue

    # Skip non-service units
    [[ "$service" == *.service ]] || continue

    # Check if the unit file is known to systemd
    if ! systemctl cat "$service" &>/dev/null; then
        echo "RakuOS overlay services: $service not found by systemd, skipping."
        continue
    fi

    if systemctl is-active --quiet "$service"; then
        echo "RakuOS overlay services: $service already active, skipping."
        continue
    fi

    echo "RakuOS overlay services: enabling and starting $service..."
    # Re-enable to repair any broken symlinks, then start
    systemctl enable "$service" 2>/dev/null || true
    systemctl start "$service" \
        && echo "RakuOS overlay services: $service started OK." \
        || echo "RakuOS overlay services: WARNING — failed to start $service"

done < <(find "$SERVICE_DIR" -maxdepth 1 -name "*.service" -type f -print0 2>/dev/null)

echo "RakuOS overlay services: done."

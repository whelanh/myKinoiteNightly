#!/usr/bin/env bash
set -euo pipefail

PACKAGES_LIST="/var/lib/rakuos/packages.list"
LOCAL_RPM_LIST="/var/lib/rakuos/packages-rpm.list"
LOCAL_RPM_CACHE="/var/lib/rakuos/local-rpms"
UPPER_DIR="/var/lib/rakuos/overlay/upper"
WORK_DIR="/var/lib/rakuos/overlay/work"
SERVICE_DIR="$UPPER_DIR/lib/systemd/system"
STATE_FILE="/var/lib/rakuos/overlay.state"
DIRTY_FILE="/var/lib/rakuos/overlay.dirty"
LOCK_FILE="/run/rakuos-overlay.lock"
PKG_CACHE_DIR="/var/cache/libdnf5"
OS_VERSION_FILE="/var/lib/rakuos/os-version"
IMAGE_PKGS_SAVE="/var/lib/rakuos/image-packages.toml"
OVERLAY_PKGS="/var/lib/rakuos/overlay/upper/lib/sysimage/libdnf5/packages.toml"
OVERLAY_RPM_DB_PATH="$UPPER_DIR/share/rpm"
BASE_RPM_DB_SNAPSHOT="/var/lib/rakuos/base-rpmdb"
MODIFIED_BASE_LIST="/var/lib/rakuos/overlay-modified-base.list"
PRE_UPDATE_RPMDB="/var/lib/rakuos/pre-update-overlay-rpmdb"
SETUP_COMPLETE="/var/lib/rakuos/setup-complete"

# --initial-install: called directly by the initial-setup app on first boot to drive
# the first package install.  Bypasses the setup-complete guard so the setup wizard
# can run the full install path before setup-complete is written.
INITIAL_INSTALL=false
for _arg in "$@"; do
    [[ "$_arg" == "--initial-install" ]] && INITIAL_INSTALL=true && break
done

# Detect live environment — root is already a writable dmsquash-live overlay.
# Skip our overlay mount; still install packages from packages.list.
IS_LIVE=false
if grep -q 'rd\.live\.image\|live\|liveimg' /proc/cmdline 2>/dev/null || \
   [[ -e /run/initramfs/livedev ]]; then
    IS_LIVE=true
fi

# Install cached local RPMs (packages installed from .rpm files, not repos).
# Reads packages-rpm.list and installs each from the local-rpms cache.
_install_local_rpms() {
    [[ -f "$LOCAL_RPM_LIST" ]] && [[ -s "$LOCAL_RPM_LIST" ]] || return 0
    local rpms_to_install=()
    while IFS= read -r pkg_name; do
        [[ -z "$pkg_name" ]] && continue
        local rpm_file="$LOCAL_RPM_CACHE/${pkg_name}.rpm"
        if [[ -f "$rpm_file" ]]; then
            rpms_to_install+=("$rpm_file")
        else
            echo "RakuOS overlay sync: WARNING — cached RPM for $pkg_name not found at $rpm_file, skipping."
        fi
    done < "$LOCAL_RPM_LIST"
    if [[ ${#rpms_to_install[@]} -gt 0 ]]; then
        echo "RakuOS overlay sync: reinstalling ${#rpms_to_install[@]} local RPM(s)..."
        _run_dnf5_with_plugin_retry install -y --config="/usr/share/rakuos/dnf.conf" "${rpms_to_install[@]}"
    fi
}

# Import Terra GPG keys for the current Fedora version (idempotent — rpm ignores already-imported keys)
_import_terra_keys() {
    local fedora_version
    fedora_version=$(. /etc/os-release && echo "$VERSION_ID")
    if [[ -z "$fedora_version" ]]; then
        echo "RakuOS overlay sync: could not determine Fedora version — skipping Terra key import."
        return 0
    fi
    if ! _internet_available; then
        echo "RakuOS overlay sync: no internet detected — skipping Terra key import."
        return 0
    fi
    echo "RakuOS overlay sync: importing Terra GPG keys for Fedora ${fedora_version}..."
    rpm --import "https://repos.fyralabs.com/terra${fedora_version}/key.asc" || true
    rpm --import "https://repos.fyralabs.com/terra${fedora_version}-mesa/key.asc" || true
    rpm --import "https://repos.fyralabs.com/terra${fedora_version}-multimedia/key.asc" || true
    #rpm --import "https://repos.fyralabs.com/terra${fedora_version}-nvidia/key.asc" || true
    echo "RakuOS overlay sync: Terra key import complete."
}

# Ensure /usr/lib/sysimage/libdnf5/packages.toml exists in the overlay upper
# so dnf5 doesn't fail with "error opening file" on first run.
_ensure_packages_toml() {
    # Check via the overlay-mounted path — covers both lower and upper layers.
    if [[ ! -f "/usr/lib/sysimage/libdnf5/packages.toml" ]]; then
        mkdir -p "$(dirname "$OVERLAY_PKGS")"
        touch "$OVERLAY_PKGS"
        chmod 644 "$OVERLAY_PKGS"
        echo "RakuOS overlay sync: created empty packages.toml for dnf5."
    fi
}

# Merge packages.toml changes from the saved image reference into the overlay's
# copy.  Additions are appended; removals are deleted — the file is never fully
# rewritten so libdnf5's strict toml++ parser always sees its own format.
_merge_packages_toml() {
    [[ -f "$IMAGE_PKGS_SAVE" ]] || { echo "RakuOS overlay sync: no image-packages.toml reference — skipping merge."; return 0; }

    # If the file only lives in the lower layer (image), promote it to the upper
    # so dnf5 can write to it and so the merge has a writable copy to update.
    if [[ ! -f "$OVERLAY_PKGS" ]]; then
        local mounted_path="/usr/lib/sysimage/libdnf5/packages.toml"
        if [[ -f "$mounted_path" ]]; then
            mkdir -p "$(dirname "$OVERLAY_PKGS")"
            cp "$mounted_path" "$OVERLAY_PKGS"
            chmod 644 "$OVERLAY_PKGS"
            echo "RakuOS overlay sync: promoted packages.toml from image lower layer to overlay upper."
        else
            echo "RakuOS overlay sync: no overlay packages.toml — skipping merge."
            return 0
        fi
    fi

    # Extract quoted "name.arch" keys from each file, one per line, sorted.
    # Lines look like: "name.arch" = {reason = "..."}
    local img_keys_f ovl_keys_f
    img_keys_f=$(mktemp)
    ovl_keys_f=$(mktemp)
    grep '^"' "$IMAGE_PKGS_SAVE" | sed 's/^\("[^"]*"\).*/\1/' | LC_ALL=C sort > "$img_keys_f"
    grep '^"' "$OVERLAY_PKGS"    | sed 's/^\("[^"]*"\).*/\1/' | LC_ALL=C sort > "$ovl_keys_f"

    # Additions: in new image but not in overlay
    local added_keys
    added_keys=$(LC_ALL=C comm -23 "$img_keys_f" "$ovl_keys_f")

    # Candidates for removal: in overlay but not in new image
    local maybe_remove
    maybe_remove=$(LC_ALL=C comm -13 "$img_keys_f" "$ovl_keys_f")
    rm -f "$img_keys_f" "$ovl_keys_f"

    # Filter removals — keep if user-installed or dnf5 tracks as "User"
    local to_remove=""
    while IFS= read -r key; do
        [[ -z "$key" ]] && continue
        local name base
        name="${key:1:${#key}-2}"   # strip surrounding quotes → name.arch
        base="${name%.*}"            # strip arch suffix → name
        # Keep if in packages.list (check bare name and name.arch)
        if [[ -f "$PACKAGES_LIST" ]]; then
            grep -qxF "$base" "$PACKAGES_LIST" 2>/dev/null && continue
            grep -qxF "$name" "$PACKAGES_LIST" 2>/dev/null && continue
        fi
        # Keep if dnf5 marked as User-installed
        grep -F "${key} " "$OVERLAY_PKGS" 2>/dev/null | grep -qiF '"User"' && continue
        to_remove+="${key}"$'\n'
    done <<< "$maybe_remove"

    [[ -z "$added_keys" && -z "$to_remove" ]] && {
        echo "RakuOS overlay sync: packages.toml already up to date — nothing to merge."
        return 0
    }

    local tmp n_added=0 n_removed=0
    tmp=$(mktemp)
    cp "$OVERLAY_PKGS" "$tmp"

    # Append new image entries (exact lines preserved — no TOML rewriting)
    if [[ -n "$added_keys" ]]; then
        while IFS= read -r key; do
            [[ -z "$key" ]] && continue
            grep -F "${key} " "$IMAGE_PKGS_SAVE" >> "$tmp" || true
            (( n_added++ )) || true
        done <<< "$added_keys"
    fi

    # Delete obsolete entries line-by-line using fixed-string match
    if [[ -n "$to_remove" ]]; then
        while IFS= read -r key; do
            [[ -z "$key" ]] && continue
            local tmp2
            tmp2=$(mktemp)
            grep -vF "${key} " "$tmp" > "$tmp2" && mv "$tmp2" "$tmp" || rm -f "$tmp2"
            (( n_removed++ )) || true
        done <<< "$to_remove"
    fi

    chmod 644 "$tmp"
    mv "$tmp" "$OVERLAY_PKGS"
    echo "RakuOS overlay sync: packages.toml merged — +${n_added} added, -${n_removed} removed."
}

# Record which packages in the overlay RPM db are also in base-packages.txt.
# This gives _handback_base_packages a focused list to check rather than scanning
# every overlay package on every image update.  Safe to call after any dnf install.
_update_modified_base_list() {
    [[ -d "$OVERLAY_RPM_DB_PATH" ]] || return 0
    [[ -d "$BASE_RPM_DB_SNAPSHOT" ]] || return 0
    local base_packages_file="/usr/share/rakuos/base-packages.txt"
    [[ -f "$base_packages_file" ]] || return 0

    # A base package is only "overriding" the base image if it is listed in
    # base-packages.txt AND the overlay db has it at a NEWER version than the
    # base snapshot.  Packages at the same version are just the seeded copy.
    local tmp_list
    tmp_list=$(mktemp)

    while IFS=' ' read -r pkg_name ovl_evr; do
        [[ -z "$pkg_name" ]] && continue
        grep -qx "$pkg_name" "$base_packages_file" 2>/dev/null || continue
        local base_evr
        base_evr=$(rpm --dbpath "$BASE_RPM_DB_SNAPSHOT" -q "$pkg_name" \
            --qf '%{EPOCH}:%{VERSION}-%{RELEASE}' 2>/dev/null) || true
        [[ -z "$base_evr" ]] && continue  # not in base snapshot
        local base_ver ovl_ver
        base_ver="${base_evr#0:}"
        ovl_ver="${ovl_evr#0:}"
        [[ "$base_ver" == "$ovl_ver" ]] && continue  # same version — seeded, not overriding
        local newer
        newer=$(printf '%s\n%s\n' "$base_ver" "$ovl_ver" | sort -V | tail -1)
        [[ "$newer" == "$ovl_ver" ]] && echo "$pkg_name" >> "$tmp_list" || true
    done < <(rpm --dbpath "$OVERLAY_RPM_DB_PATH" -qa \
        --qf '%{NAME} %{EPOCH}:%{VERSION}-%{RELEASE}\n' 2>/dev/null)

    sort -u "$tmp_list" > "$MODIFIED_BASE_LIST"
    rm -f "$tmp_list"

    local count
    count=$(wc -l < "$MODIFIED_BASE_LIST" 2>/dev/null || echo 0)
    echo "RakuOS overlay sync: modified-base list updated — $count base package(s) overriding base image."
}

# For packages now provided by the new base image at the same or newer version,
# remove their files from the overlay upper dir so the base image takes back over.
# Packages where the overlay is still newer are kept and left in the tracking list.
_handback_base_packages() {
    [[ -d "$OVERLAY_RPM_DB_PATH" ]] || return 0
    if [[ ! -d "$BASE_RPM_DB_SNAPSHOT" ]] || [[ -z "$(ls -A "$BASE_RPM_DB_SNAPSHOT" 2>/dev/null)" ]]; then
        echo "RakuOS overlay sync: no base-rpmdb snapshot — skipping handback."
        return 0
    fi

    local base_packages_file="/usr/share/rakuos/base-packages.txt"
    [[ -f "$base_packages_file" ]] || return 0

    if [[ ! -f "$MODIFIED_BASE_LIST" ]] || [[ ! -s "$MODIFIED_BASE_LIST" ]]; then
        echo "RakuOS overlay sync: no base packages tracked in overlay — skipping handback."
        return 0
    fi

    echo "RakuOS overlay sync: checking tracked base package(s) for handback..."
    local handed_back=0 kept=0
    local tmp_list
    tmp_list=$(mktemp)

    while IFS= read -r pkg_name; do
        [[ -z "$pkg_name" ]] && continue

        # Verify it is actually a base image package
        grep -qx "$pkg_name" "$base_packages_file" 2>/dev/null || continue

        # Get version from base snapshot
        local base_evr
        base_evr=$(rpm --dbpath "$BASE_RPM_DB_SNAPSHOT" -q "$pkg_name" \
            --qf '%{EPOCH}:%{VERSION}-%{RELEASE}' 2>/dev/null) || true
        [[ -z "$base_evr" ]] && continue  # not in new base image

        # Get version from overlay db
        local ovl_evr
        ovl_evr=$(rpm --dbpath "$OVERLAY_RPM_DB_PATH" -q "$pkg_name" \
            --qf '%{EPOCH}:%{VERSION}-%{RELEASE}' 2>/dev/null) || true
        if [[ -z "$ovl_evr" ]]; then
            continue  # not in overlay db — already gone, drop from list
        fi

        local base_ver ovl_ver
        base_ver="${base_evr#0:}"
        ovl_ver="${ovl_evr#0:}"

        # Hand back if base image version >= overlay version
        local newer
        newer=$(printf '%s\n%s\n' "$ovl_ver" "$base_ver" | sort -V | tail -1)
        if [[ "$newer" == "$base_ver" ]]; then
            echo "  Handing back: $pkg_name (overlay: $ovl_ver → base: $base_ver)"
            local removed_files=0
            while IFS= read -r fpath; do
                [[ "$fpath" == /usr/* ]] || continue
                local upper_path="$UPPER_DIR/${fpath#/usr/}"
                if [[ -f "$upper_path" ]] || [[ -L "$upper_path" ]]; then
                    rm -f "$upper_path"
                    (( removed_files++ )) || true
                fi
            done < <(rpm --dbpath "$OVERLAY_RPM_DB_PATH" -ql "$pkg_name" 2>/dev/null)
            # Remove now-empty directories in the upper dir
            while IFS= read -r fpath; do
                [[ "$fpath" == /usr/* ]] || continue
                local upper_dir
                upper_dir="$UPPER_DIR/$(dirname "${fpath#/usr/}")"
                [[ -d "$upper_dir" ]] && rmdir --ignore-fail-on-non-empty "$upper_dir" 2>/dev/null || true
            done < <(rpm --dbpath "$OVERLAY_RPM_DB_PATH" -ql "$pkg_name" 2>/dev/null)
            echo "    Removed $removed_files file(s) from overlay upper."
            (( handed_back++ )) || true
            # Do NOT write to tmp_list — removed from tracking
        else
            # Overlay is still newer than base — keep it tracked
            echo "$pkg_name" >> "$tmp_list"
            (( kept++ )) || true
        fi
    done < "$MODIFIED_BASE_LIST"

    # Write back only packages NOT handed back
    sort -u "$tmp_list" > "$MODIFIED_BASE_LIST"
    rm -f "$tmp_list"

    echo "RakuOS overlay sync: handed back $handed_back package(s) to base image, kept $kept package(s) in overlay."
}

# Reset the overlay RPM database to the base image state, then re-register
# overlay-specific packages from the pkgcache.
_rebuild_overlay_rpmdb() {
    echo "RakuOS overlay sync: rebuilding overlay RPM database..."

    if [[ ! -d "$BASE_RPM_DB_SNAPSHOT" ]] || [[ -z "$(ls -A "$BASE_RPM_DB_SNAPSHOT" 2>/dev/null)" ]]; then
        echo "RakuOS overlay sync: WARNING — no base-rpmdb snapshot found, skipping db rebuild."
        return 0
    fi

    # Reset overlay RPM db to fresh base image state
    mkdir -p "$OVERLAY_RPM_DB_PATH"
    cp -a "$BASE_RPM_DB_SNAPSHOT/." "$OVERLAY_RPM_DB_PATH/"
    rm -f "$OVERLAY_RPM_DB_PATH"/.rpm.lock "$OVERLAY_RPM_DB_PATH"/__db.*
    echo "RakuOS overlay sync: overlay RPM db reset to base image state."

    # Re-register overlay packages from pkgcache.
    # Process newest RPMs first (handles multiple versions of same package in cache).
    # - Base packages that were handed back (not in MODIFIED_BASE_LIST) → skip
    # - Base packages still in MODIFIED_BASE_LIST (overlay newer than base) → register
    # - Non-base packages → only register if confirmed installed in pre-update snapshot
    #   (guards against stale cached .rpms for packages the user uninstalled)
    local registered=0 skipped=0 failed=0
    while IFS= read -r rpm_file; do
        local pkg_name
        pkg_name=$(rpm -qp --qf '%{NAME}' "$rpm_file" 2>/dev/null) || { (( failed++ )) || true; continue; }

        # If this is a base image package, only register if overlay is still newer
        if rpm --dbpath "$BASE_RPM_DB_SNAPSHOT" -q "$pkg_name" &>/dev/null; then
            if ! grep -qx "$pkg_name" "$MODIFIED_BASE_LIST" 2>/dev/null; then
                (( skipped++ )) || true
                continue
            fi
        fi

        # Skip if already re-registered (duplicate package version in cache)
        if rpm --dbpath /usr/share/rpm -q "$pkg_name" &>/dev/null; then
            continue
        fi

        # Verify the package was actually installed in the overlay at last boot.
        # The pre-update snapshot is written by rakuos-overlay-mount before mounting;
        # if it exists and the package is absent from it, the .rpm is a stale cache
        # entry for a package the user already uninstalled — do not re-register it.
        if [[ -d "$PRE_UPDATE_RPMDB" ]]; then
            if ! rpm --dbpath "$PRE_UPDATE_RPMDB" -q "$pkg_name" &>/dev/null; then
                echo "  Skipping $pkg_name — not installed in overlay at last boot (stale cache)."
                (( skipped++ )) || true
                continue
            fi
        fi

        if rpm --dbpath /usr/share/rpm --justdb -i --nodeps --nosignature "$rpm_file" 2>/dev/null; then
            (( registered++ )) || true
        else
            (( failed++ )) || true
        fi
    done < <(find "$PKG_CACHE_DIR" -name "*.rpm" -type f -printf '%T@ %p\n' 2>/dev/null \
        | sort -rn | cut -d' ' -f2-)

    # Re-register locally-installed RPMs from the local-rpms cache.
    # These aren't in PKG_CACHE_DIR so they're missed by the loop above.
    # Use --justdb because the files are already present in the overlay upper dir.
    local local_registered=0 local_skipped=0 local_failed=0
    if [[ -f "$LOCAL_RPM_LIST" ]] && [[ -s "$LOCAL_RPM_LIST" ]]; then
        while IFS= read -r pkg_name; do
            [[ -z "$pkg_name" ]] && continue
            local rpm_file="$LOCAL_RPM_CACHE/${pkg_name}.rpm"
            if [[ ! -f "$rpm_file" ]]; then
                echo "  WARNING — cached RPM for $pkg_name not found at $rpm_file, skipping."
                continue
            fi
            # Skip if already registered (shouldn't happen but be safe)
            if rpm --dbpath /usr/share/rpm -q "$pkg_name" &>/dev/null; then
                continue
            fi
            # Verify it was actually installed at last boot — packages-rpm.list may
            # still list a package the user later removed, and its .rpm stays in cache.
            if [[ -d "$PRE_UPDATE_RPMDB" ]]; then
                if ! rpm --dbpath "$PRE_UPDATE_RPMDB" -q "$pkg_name" &>/dev/null; then
                    echo "  Skipping local $pkg_name — not installed in overlay at last boot (stale entry)."
                    (( local_skipped++ )) || true
                    continue
                fi
            fi
            if rpm --dbpath /usr/share/rpm --justdb -i --nodeps --nosignature "$rpm_file" 2>/dev/null; then
                (( local_registered++ )) || true
            else
                (( local_failed++ )) || true
            fi
        done < "$LOCAL_RPM_LIST"
        echo "RakuOS overlay sync: local RPMs re-registered — registered: $local_registered, skipped: $local_skipped, failed: $local_failed."
    fi

    rpm --rebuilddb --dbpath /usr/share/rpm 2>/dev/null || true
    echo "RakuOS overlay sync: RPM db rebuilt — registered: $registered, handed to base: $skipped, failed: $failed."
}

# Save any GPG keys imported into the overlay RPM db that are not in the base
# snapshot (Terra, COPR, etc.) so they survive a db re-seed.
_save_overlay_gpg_keys() {
    [[ -d "$OVERLAY_RPM_DB_PATH" ]] || return 0
    local save_dir="/var/lib/rakuos/saved-gpg-keys"
    mkdir -p "$save_dir"
    rm -f "$save_dir"/*.asc
    local count=0
    while IFS= read -r key_pkg; do
        [[ -z "$key_pkg" ]] && continue
        # Skip keys already present in the base snapshot — they'll come back via seed
        rpm --dbpath "$BASE_RPM_DB_SNAPSHOT" -q "$key_pkg" &>/dev/null && continue
        rpm --dbpath "$OVERLAY_RPM_DB_PATH" -q --qf '%{DESCRIPTION}\n' "$key_pkg" 2>/dev/null \
            > "$save_dir/${key_pkg}.asc" || true
        (( count++ )) || true
    done < <(rpm --dbpath "$OVERLAY_RPM_DB_PATH" -qa --qf '%{NAME}-%{VERSION}-%{RELEASE}\n' \
        2>/dev/null | grep '^gpg-pubkey-')
    echo "RakuOS overlay sync: saved $count third-party GPG key(s) before seed."
}

# Re-import saved GPG keys into the freshly seeded overlay RPM db.
_restore_overlay_gpg_keys() {
    local save_dir="/var/lib/rakuos/saved-gpg-keys"
    [[ -d "$save_dir" ]] || return 0
    local count=0
    for key_file in "$save_dir"/*.asc; do
        [[ -f "$key_file" ]] && [[ -s "$key_file" ]] || continue
        rpm --dbpath /usr/share/rpm --import "$key_file" 2>/dev/null \
            && (( count++ )) || true
    done
    echo "RakuOS overlay sync: restored $count GPG key(s) after seed."
}

# Seed the overlay upper dir's RPM database from the base image before a fresh
# install.  Prefer the saved snapshot (available after a normal boot); fall back
# to /usr/share/rpm directly (accessible when overlay is freshly mounted empty).
_seed_overlay_rpmdb() {
    # The mount script pre-seeds the db before exiting on first boot / reset /
    # migration.  Skip here if it already did the work.
    if [[ -d "$OVERLAY_RPM_DB_PATH" ]] && [[ -n "$(ls -A "$OVERLAY_RPM_DB_PATH" 2>/dev/null)" ]]; then
        echo "RakuOS overlay sync: overlay RPM database already seeded by mount script — skipping."
        return 0
    fi
    echo "RakuOS overlay sync: seeding overlay RPM database from base image..."
    local source_db
    if [[ -d "$BASE_RPM_DB_SNAPSHOT" ]] && [[ -n "$(ls -A "$BASE_RPM_DB_SNAPSHOT" 2>/dev/null)" ]]; then
        source_db="$BASE_RPM_DB_SNAPSHOT"
    else
        source_db="/usr/share/rpm"
    fi
    mkdir -p "$OVERLAY_RPM_DB_PATH"
    cp -a "$source_db/." "$OVERLAY_RPM_DB_PATH/"
    rm -f "$OVERLAY_RPM_DB_PATH"/.rpm.lock "$OVERLAY_RPM_DB_PATH"/__db.*
    echo "RakuOS overlay sync: overlay RPM database seeded from $source_db."
}

# Send a message to the Plymouth splash screen if it is running.
# Silently does nothing if Plymouth is absent or has already handed off to the DM.
_plymsg() {
    plymouth --ping 2>/dev/null && plymouth display-message --text="$1" 2>/dev/null || true
}

# Return success when the system appears to have usable internet access for
# repo-backed dnf operations.  Keep the probe lightweight so first boot does not
# hang for long on machines with no network configured yet.
_internet_available() {
    command -v curl >/dev/null 2>&1 || return 1
    if command -v nmcli >/dev/null 2>&1; then
        nmcli -t -f TYPE,STATE device 2>/dev/null \
            | grep -qE '^(ethernet|wifi):(connected|connecting)$' || return 1
    fi
    curl -fsSLI --max-time 2 --connect-timeout 1 https://mirrors.fedoraproject.org/ >/dev/null 2>&1
}

# If there is no internet, skip repo-backed install work and let boot continue
# so the user can reach the desktop, configure networking, and retry on reboot.
_skip_if_no_internet() {
    local context="$1"
    if _internet_available; then
        return 0
    fi

    echo "RakuOS overlay sync: no internet detected during ${context} — skipping package install for now."
    _plymsg "No internet detected. Skipping package install for now."
    return 1
}

# If dnf5 fails because a libdnf plugin config exists but the plugin library
# has disappeared from the new image, remove the stale config(s) and retry once.
_cleanup_stale_dnf_plugin_confs() {
    local dnf_output="$1"
    local removed_any=1
    local conf

    while IFS= read -r conf; do
        [[ -n "$conf" ]] || continue
        if [[ -f "$conf" ]]; then
            rm -f "$conf"
            echo "RakuOS overlay sync: removed stale libdnf plugin config $conf"
            removed_any=0
        fi
    done < <(printf '%s\n' "$dnf_output" | sed -n 's/^Cannot load libdnf plugin enabled from: \(.*\.conf\)$/\1/p')

    return "$removed_any"
}

_run_dnf5_with_plugin_retry() {
    local output status

    set +e
    output=$(dnf5.real "$@" 2>&1)
    status=$?
    set -e

    [[ -n "$output" ]] && printf '%s\n' "$output"
    if [[ $status -eq 0 ]]; then
        return 0
    fi

    if ! _cleanup_stale_dnf_plugin_confs "$output"; then
        return "$status"
    fi

    echo "RakuOS overlay sync: retrying dnf5 after removing stale plugin config(s)..."
    dnf5.real "$@"
}

# Acquire lock so rakuos-base-protect allows our overlay writes
touch "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT


# ── Live environment — go straight to desktop ─────────────────────────────────
if [[ "$IS_LIVE" == "true" ]]; then
    echo "RakuOS overlay sync: live environment..."
    # The live squashfs now carries the default app set directly. Do not try to
    # perform overlay/package setup here; installed systems will handle the real
    # overlay on first boot after install. Anaconda already places its own
    # installer shortcuts in the live session.
    _plymsg "Live environment ready."
    echo "RakuOS overlay sync: live environment ready — skipping overlay sync."
    plymouth --ping 2>/dev/null && plymouth quit 2>/dev/null || true
    exit 0
fi

# Read packages into array, skip empty lines and comments
mapfile -t PACKAGES < <(
    grep -v '^\s*#' "$PACKAGES_LIST" \
    | grep -v '^\s*$' \
    | sed 's/\s*#.*//' \
    | tr -s ' \t' '\n' \
    | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
    | grep -v '^$'
)

if [[ "${#PACKAGES[@]}" -eq 0 ]]; then
    echo "RakuOS overlay sync: no packages in list — skipping."
    exit 0
fi

# ── Normal (installed system) path ────────────────────────────────────────────

# Ensure overlay dirs exist
mkdir -p "$UPPER_DIR" "$WORK_DIR"

# Get current booted image digest
CURRENT_DIGEST=$(bootc status --json | jq -r '.status.booted.image.imageDigest // empty')
if [[ -z "$CURRENT_DIGEST" ]]; then
    echo "WARNING: Could not detect image digest — using unknown."
    CURRENT_DIGEST="unknown"
fi

SAVED_DIGEST=$(cat "$STATE_FILE" 2>/dev/null || echo "")

# Mount overlay if not already mounted
if ! findmnt /usr | grep -q overlay; then
    echo "RakuOS overlay sync: mounting overlay..."
    mount -t overlay overlay \
        -o lowerdir=/usr,upperdir="$UPPER_DIR",workdir="$WORK_DIR" \
        /usr
fi

# Import Terra GPG keys into the overlay RPM db now that /usr/share/rpm is
# writable through the overlay mount.  Covers dirty and image-update paths.
# The full install path calls this again after re-seeding the db.
_import_terra_keys

# ── Determine what needs doing ────────────────────────────────────────────────

OVERLAY_HAS_CONTENT=false
if [[ -n "$(ls -A "$UPPER_DIR" 2>/dev/null)" ]]; then
    OVERLAY_HAS_CONTENT=true
fi

# A missing STATE_FILE means either:
#   - fresh first boot (packages.list just seeded by mount script), or
#   - post-reset (mount script wiped state and re-seeded packages.list)
# Either way: full install needed.
STATE_MISSING=false
if [[ -z "$SAVED_DIGEST" ]]; then
    STATE_MISSING=true
fi

if [[ "$STATE_MISSING" == "true" ]] || [[ "$OVERLAY_HAS_CONTENT" == "false" ]]; then
    echo "RakuOS overlay sync: overlay empty or state missing — performing full install..."
    _plymsg "Wiping overlay and reinstalling default applications..."
    if ! _skip_if_no_internet "first boot or reset install"; then
        _plymsg "Connect to the internet, then reboot to finish installing default applications."
        echo "RakuOS overlay sync: deferring full install until network is available."
        plymouth --ping 2>/dev/null && plymouth quit 2>/dev/null || true
        exit 0
    fi
    _save_overlay_gpg_keys
    _seed_overlay_rpmdb
    # Restore third-party keys (COPR, etc.) saved before the seed, then re-import
    # Terra keys since the seeded db may not have the latest rotated keys.
    _restore_overlay_gpg_keys
    _import_terra_keys
    _ensure_packages_toml
    _plymsg "Installing default applications..."
    _run_dnf5_with_plugin_retry install -y --refresh --config="/usr/share/rakuos/dnf.conf" \
        "${PACKAGES[@]}"
    _install_local_rpms
    _update_modified_base_list
    echo "$CURRENT_DIGEST" > "$STATE_FILE"
    rm -f "$DIRTY_FILE"
    _plymsg "Default applications installed."
    echo "RakuOS overlay sync: full install complete."

elif [[ "$CURRENT_DIGEST" != "$SAVED_DIGEST" ]]; then
    echo "RakuOS overlay sync: image updated — syncing overlay with new base image..."
    _plymsg "Updating overlay package database..."
    _merge_packages_toml
    _handback_base_packages
    _plymsg "Rebuilding package database..."
    _rebuild_overlay_rpmdb
    echo "$CURRENT_DIGEST" > "$STATE_FILE"
    rm -f "$DIRTY_FILE"
    _plymsg "Overlay package database updated."
    echo "RakuOS overlay sync: image update sync complete."

elif [[ -f "$DIRTY_FILE" ]]; then
    echo "RakuOS overlay sync: package changes detected — syncing..."
    _plymsg "Wiping overlay and reinstalling user applications..."
    if ! _skip_if_no_internet "overlay reinstall"; then
        _plymsg "Connect to the internet, then reboot to finish reinstalling applications."
        echo "RakuOS overlay sync: deferring dirty overlay reinstall until network is available."
        plymouth --ping 2>/dev/null && plymouth quit 2>/dev/null || true
        exit 0
    fi
    _ensure_packages_toml
    _run_dnf5_with_plugin_retry install -y --refresh --config="/usr/share/rakuos/dnf.conf" \
        "${PACKAGES[@]}"
    _install_local_rpms
    _update_modified_base_list
    rm -f "$DIRTY_FILE"
    _plymsg "User applications reinstalled."
    echo "RakuOS overlay sync: sync complete."

else
    echo "RakuOS overlay sync: nothing to do."
fi

# Save digest
echo "$CURRENT_DIGEST" > "$STATE_FILE"

echo "RakuOS overlay sync: done."

# ── RakuOS version stamp (runs every boot after sync completes) ────────────────
mkdir -p "$(dirname "$OS_VERSION_FILE")"

if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "${VERSION_ID:-unknown}" > "$OS_VERSION_FILE"
else
    echo "unknown" > "$OS_VERSION_FILE"
fi


# Hand Plymouth back — the display manager will take over the screen now.
# plymouth-quit.service will do this too, but signalling it here lets the DM
# start (and Plymouth transition) without the extra 20-second timeout window.
plymouth --ping 2>/dev/null && plymouth quit 2>/dev/null || true

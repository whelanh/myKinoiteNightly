#!/usr/bin/env bash
set -euo pipefail

PACKAGES=("${@}")
PACKAGES_LIST="/var/lib/rakuos/packages.list"
LOCAL_RPM_LIST="/var/lib/rakuos/packages-rpm.list"
LOCAL_RPM_CACHE="/var/lib/rakuos/local-rpms"
UPPER_DIR="/var/lib/rakuos/overlay/upper"
WORK_DIR="/var/lib/rakuos/overlay/work"
DIRTY_FILE="/var/lib/rakuos/overlay.dirty"
OVERLAY_RPM_DB="$UPPER_DIR/share/rpm"
BASE_RPM_DB_SNAPSHOT="/var/lib/rakuos/base-rpmdb"
BASE_PACKAGES_FILE="/usr/share/rakuos/base-packages.txt"
MODIFIED_BASE_LIST="/var/lib/rakuos/overlay-modified-base.list"

# Rebuild the modified-base tracking list by scanning the overlay RPM db.
# Packages at a newer version than the base snapshot are tracked for handback.
_update_modified_base_list() {
    [[ -d "$OVERLAY_RPM_DB" ]] || return 0
    [[ -d "$BASE_RPM_DB_SNAPSHOT" ]] || return 0
    [[ -f "$BASE_PACKAGES_FILE" ]] || return 0
    local tmp_list
    tmp_list=$(mktemp)
    while IFS=' ' read -r pkg_name ovl_evr; do
        [[ -z "$pkg_name" ]] && continue
        grep -qx "$pkg_name" "$BASE_PACKAGES_FILE" 2>/dev/null || continue
        local base_evr
        base_evr=$(rpm --dbpath "$BASE_RPM_DB_SNAPSHOT" -q "$pkg_name" \
            --qf '%{EPOCH}:%{VERSION}-%{RELEASE}' 2>/dev/null) || true
        [[ -z "$base_evr" ]] && continue
        local base_ver ovl_ver
        base_ver="${base_evr#0:}"
        ovl_ver="${ovl_evr#0:}"
        [[ "$base_ver" == "$ovl_ver" ]] && continue
        local newer
        newer=$(printf '%s\n%s\n' "$base_ver" "$ovl_ver" | sort -V | tail -1)
        [[ "$newer" == "$ovl_ver" ]] && echo "$pkg_name" >> "$tmp_list" || true
    done < <(rpm --dbpath "$OVERLAY_RPM_DB" -qa \
        --qf '%{NAME} %{EPOCH}:%{VERSION}-%{RELEASE}\n' 2>/dev/null)
    sort -u "$tmp_list" > "$MODIFIED_BASE_LIST"
    rm -f "$tmp_list"
}

if [[ "${#PACKAGES[@]}" -eq 0 ]]; then
    echo "Usage: rakuos remove <package> [package2] [package3]..."
    exit 1
fi

# Must run as root
if [[ "$EUID" -ne 0 ]]; then
    echo "ERROR: rakuos remove must be run as root"
    exit 1
fi

# Detect live environment — root is already a writable dmsquash-live overlay.
# Skip the overlay mount; list tracking and remove still run normally.
IS_LIVE=false
if grep -q 'rd\.live\.image\|live\|liveimg' /proc/cmdline 2>/dev/null || \
   [[ -e /run/initramfs/livedev ]]; then
    IS_LIVE=true
fi

# Acquire lock so rakuos-base-protect allows our overlay writes
LOCK_FILE="/run/rakuos-overlay.lock"
touch "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# Filter out packages not in the overlay list
# packages.list is the source of truth — if it's there, it was installed via overlay
TO_REMOVE=()
for pkg in "${PACKAGES[@]}"; do
    if grep -qx "$pkg" "$PACKAGES_LIST" 2>/dev/null || grep -qx "$pkg" "$LOCAL_RPM_LIST" 2>/dev/null; then
        TO_REMOVE+=("$pkg")
    else
        echo "$pkg is not in the RakuOS package list — skipping."
    fi
done

if [[ "${#TO_REMOVE[@]}" -eq 0 ]]; then
    echo "None of the requested packages are in the RakuOS package list."
    exit 0
fi

echo "Removing ${TO_REMOVE[*]}..."

# Mount our persistent overlay if not already active (skip on live — root already writable)
if [[ "$IS_LIVE" != "true" ]] && ! findmnt /usr | grep -q overlay; then
    echo "Mounting RakuOS overlay..."
    mount -t overlay overlay \
        -o lowerdir=/usr,upperdir="$UPPER_DIR",workdir="$WORK_DIR" \
        /usr
fi

# Remove live from overlay
dnf5.real remove -y --config="/usr/share/rakuos/dnf.conf" "${TO_REMOVE[@]}" || echo "Warning: dnf5.real remove returned non-zero, may already be gone."

# Remove each from the appropriate list and clean up local RPM cache if applicable
for pkg in "${TO_REMOVE[@]}"; do
    sed -i "/^${pkg}$/d" "$PACKAGES_LIST"
    if grep -qx "$pkg" "$LOCAL_RPM_LIST" 2>/dev/null; then
        sed -i "/^${pkg}$/d" "$LOCAL_RPM_LIST"
        rm -f "$LOCAL_RPM_CACHE/${pkg}.rpm"
    fi
done
[[ -f "$LOCAL_RPM_LIST" ]] && chmod 644 "$LOCAL_RPM_LIST" || true

# Set dirty flag so boot service rebuilds overlay on next boot
touch "$DIRTY_FILE"

# Rebuild the modified-base tracking list from scratch so any base-image
# dependencies that were also removed (as side-effects of this removal) are
# correctly dropped from the list.
_update_modified_base_list

echo "${TO_REMOVE[*]} removed from RakuOS package list."

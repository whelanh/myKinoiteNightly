#!/usr/bin/env bash
set -euo pipefail

RAKUOS_DIR="/var/lib/rakuos"
RESET_MARKER="$RAKUOS_DIR/overlay.reset"
PKGCACHE_MIGRATED="$RAKUOS_DIR/pkgcache.migrated"
DNF_CACHE_DIR="/var/cache/libdnf5"
LOCAL_RPM_CACHE="$RAKUOS_DIR/local-rpms"
LOCAL_RPM_LIST="$RAKUOS_DIR/packages-rpm.list"

# Must run as root
if [[ "$EUID" -ne 0 ]]; then
    echo "ERROR: rakuos reset-overlay must be run as root"
    exit 1
fi

COMMAND="${1:-}"

case "$COMMAND" in
    --confirm)
        # Hard reset — wipes overlay, packages.list, local RPM cache, and dnf cache; starts completely fresh
        mkdir -p "$RAKUOS_DIR"
        touch "$RESET_MARKER"
        rm -rf "${DNF_CACHE_DIR:?}"/*
        rm -rf "${LOCAL_RPM_CACHE:?}"/*
        rm -f "$LOCAL_RPM_LIST"
        echo ""
        echo "RakuOS: overlay reset scheduled."
        echo "Please reboot — the overlay will be wiped cleanly on next boot."
        ;;

    --soft)
        # Soft reset — wipes overlay and dnf cache; packages.list is preserved so
        # all user packages are reinstalled transparently on next boot.
        mkdir -p "$RAKUOS_DIR"
        rm -f "$PKGCACHE_MIGRATED"
        rm -rf "${DNF_CACHE_DIR:?}"/*
        echo ""
        echo "RakuOS: soft reset scheduled."
        echo "Please reboot — the overlay will be rebuilt and packages reinstalled on next boot."
        ;;

    *)
        echo "WARNING: This will remove packages installed via rakuos install."
        echo "Your base system and /home will not be affected."
        echo ""
        echo "Options:"
        echo "  --confirm   Hard reset: wipes overlay and packages.list completely."
        echo "  --soft      Soft reset: wipes overlay but preserves packages.list — all"
        echo "              packages are reinstalled cleanly on next boot."
        echo ""
        echo "Usage: sudo rakuos reset-overlay [--confirm|--soft]"
        exit 1
        ;;
esac

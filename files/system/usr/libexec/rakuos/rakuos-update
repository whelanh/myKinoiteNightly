#!/usr/bin/env bash
# rakuos-update — RakuOS overlay package update manager.
# Checks and upgrades any installed package not excluded by /usr/share/rakuos/dnf.conf.
# Protected base packages (kernel, DE shell, python*, etc.) are excluded via that
# config's excludepkgs list; everything else — user packages, deps, and safe base
# packages not in excludepkgs — is eligible for upgrade.
#
# Usage:
#   rakuos-update check           — print available updates as JSON, exit 0=updates 1=none
#   rakuos-update upgrade         — perform the upgrade
#   rakuos-update check-flatpak   — print available flatpak updates as JSON
#   rakuos-update upgrade-flatpak — upgrade all flatpak apps and runtimes
#   rakuos-update check-image     — check bootc for a new system image (JSON)
#   rakuos-update upgrade-image   — run bootc update

set -euo pipefail

PACKAGES_LIST="/var/lib/rakuos/packages.list"
LOCAL_RPM_LIST="/var/lib/rakuos/packages-rpm.list"
DNF_CONF="/usr/share/rakuos/dnf.conf"
PKG_CACHE_DIR="/var/cache/libdnf5"
UPPER_DIR="/var/lib/rakuos/overlay/upper"
OVERLAY_RPM_DB="$UPPER_DIR/share/rpm"
MODIFIED_BASE_LIST="/var/lib/rakuos/overlay-modified-base.list"
COMMAND="${1:-upgrade}"

# ── Helpers ───────────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

dnf() { dnf5.real --config="$DNF_CONF" "$@"; }

# Return user-installed package names from packages.list (empty-safe).
get_user_packages() {
    [[ -s "$PACKAGES_LIST" ]] && sort -u "$PACKAGES_LIST" || true
}

# Return all managed package names: packages.list + packages-rpm.list.
get_all_managed_packages() {
    local tmp
    tmp=$(mktemp)
    [[ -s "$PACKAGES_LIST" ]] && cat "$PACKAGES_LIST" >> "$tmp" || true
    [[ -s "$LOCAL_RPM_LIST" ]] && cat "$LOCAL_RPM_LIST" >> "$tmp" || true
    sort -u "$tmp"
    rm -f "$tmp"
}

# Update the tracking list of base packages overridden in the overlay.
# Only packages at a NEWER version than the base snapshot are tracked —
# packages at the same version are just the seeded copy, not an override.
_update_modified_base_list() {
    local base_snapshot="/var/lib/rakuos/base-rpmdb"
    local base_packages_file="/usr/share/rakuos/base-packages.txt"
    [[ -d "$OVERLAY_RPM_DB" ]] || return 0
    [[ -d "$base_snapshot" ]] || return 0
    [[ -f "$base_packages_file" ]] || return 0
    local tmp_list
    tmp_list=$(mktemp)
    while IFS=' ' read -r pkg_name ovl_evr; do
        [[ -z "$pkg_name" ]] && continue
        grep -qx "$pkg_name" "$base_packages_file" 2>/dev/null || continue
        local base_evr
        base_evr=$(rpm --dbpath "$base_snapshot" -q "$pkg_name" \
            --qf '%{EPOCH}:%{VERSION}-%{RELEASE}' 2>/dev/null) || true
        [[ -z "$base_evr" ]] && continue
        local base_ver ovl_ver
        base_ver="${base_evr#0:}"
        ovl_ver="${ovl_evr#0:}"
        [[ "$base_ver" == "$ovl_ver" ]] && continue
        local newer
        newer=$(printf '%s\n%s\n' "$base_ver" "$ovl_ver" | sort -V | tail -1)
        [[ "$newer" == "$ovl_ver" ]] && echo "$pkg_name" >> "$tmp_list" || true
    done < <(rpm --dbpath "$OVERLAY_RPM_DB" -qa \
        --qf '%{NAME} %{EPOCH}:%{VERSION}-%{RELEASE}\n' 2>/dev/null)
    sort -u "$tmp_list" > "$MODIFIED_BASE_LIST"
    rm -f "$tmp_list"
}

# Detect if a package owns a .desktop file (GUI app)
# 1. RPM database (installed packages) — fastest and most accurate
# 2. Broad glob scan of /usr/share/applications/ — catches reverse-DNS names (e.g. dev.zed.Zed.desktop)
# 3. Scan Exec= fields in all .desktop files for the binary name
# 4. dnf5 repoquery — slowest, last resort for packages not yet installed
is_gui_package() {
    rpm -ql "$1" 2>/dev/null | grep -q '\.desktop$' && return 0
    ls /usr/share/applications/*.desktop 2>/dev/null | grep -qi "${1}" && return 0
    grep -ril "^Exec=.*\b${1}\b" /usr/share/applications/ 2>/dev/null | grep -q . && return 0
    dnf5 repoquery --list "$1" 2>/dev/null | grep -q '\.desktop$'
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_check() {
    echo "RakuOS: checking for package updates..." >&2

    # Only check packages managed by the overlay (packages.list + packages-rpm.list)
    # and any of their dependencies that dnf would also upgrade.
    local pkg_list=()
    while IFS= read -r p; do
        [[ -n "$p" ]] && pkg_list+=("$p")
    done < <(get_all_managed_packages)

    if [[ ${#pkg_list[@]} -eq 0 ]]; then
        echo '{"updates": []}'
        exit 1
    fi

    # dnf5 check-update exits 100 if updates are available, 0 if none.
    local check_output exit_code=0
    check_output=$(dnf check-update --refresh --quiet "${pkg_list[@]}" 2>/dev/null) || exit_code=$?

    if [[ $exit_code -eq 100 ]]; then
        local user_pkgs
        user_pkgs=$(get_user_packages)

        local json='{"updates": ['
        local first=1
        declare -A seen_names=()
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            # Skip dnf header/separator lines
            [[ "$line" =~ ^[[:space:]] ]] && continue
            [[ "$line" =~ ^Last ]] && continue
            [[ "$line" =~ ^Obsoleting ]] && continue
            local name_arch version repo name gui user_installed current_version
            name_arch=$(echo "$line" | awk '{print $1}')
            version=$(echo "$line"   | awk '{print $2}')
            repo=$(echo "$line"      | awk '{print $3}')
            # Strip arch suffix: firefox.x86_64 -> firefox
            name=$(echo "$name_arch" | sed 's/\.[a-z_0-9]*$//')
            # Strip DNF5 rename transition suffix: zed-rename-zeditor -> zed
            name=$(echo "$name" | sed 's/-rename-.*$//')
            [[ -z "$name" || -z "$version" ]] && continue
            # Deduplicate — same package can appear for multiple arches
            [[ -n "${seen_names[$name]:-}" ]] && continue
            seen_names["$name"]=1
            current_version=$(rpm -q --qf '%{VERSION}-%{RELEASE}' "$name" 2>/dev/null || echo "")
            gui="false"
            is_gui_package "$name" && gui="true"
            user_installed="false"
            echo "$user_pkgs" | grep -qx "$name" 2>/dev/null && user_installed="true"
            [[ $first -eq 0 ]] && json+=","
            json+="{\"name\":\"$name\",\"version\":\"$version\",\"current_version\":\"$current_version\",\"repo\":\"$repo\",\"gui\":$gui,\"user_installed\":$user_installed}"
            first=0
        done <<< "$check_output"
        json+="]}"
        echo "$json"
        exit 0
    else
        echo '{"updates": []}'
        exit 1
    fi
}

cmd_upgrade() {
    echo "RakuOS: upgrading packages..."

    # Upgrade only packages managed by the overlay and their required dependencies.
    # If a dep happens to be a base image package not in excludepkgs, it can upgrade.
    local pkg_list=()
    while IFS= read -r p; do
        [[ -n "$p" ]] && pkg_list+=("$p")
    done < <(get_all_managed_packages)

    if [[ ${#pkg_list[@]} -eq 0 ]]; then
        echo "RakuOS: no managed packages to upgrade."
        exit 0
    fi

    dnf upgrade -y --refresh "${pkg_list[@]}"

    # Update tracking list so the next image update's handback only checks packages
    # the overlay has actually overridden (safe base packages upgraded here land here).
    _update_modified_base_list

    echo "RakuOS: package upgrade complete."
}

cmd_upgrade_package() {
    local pkg_name="$1"
    [[ -z "$pkg_name" ]] && die "upgrade-package requires a package name argument"
    echo "RakuOS: upgrading package ${pkg_name}..."
    dnf upgrade -y --refresh "$pkg_name"
    _update_modified_base_list
    echo "RakuOS: package upgrade complete."
}

cmd_check_flatpak() {
    echo "RakuOS: checking for Flatpak updates..." >&2
    flatpak update --appstream -y &>/dev/null || true

    local json='{"updates": ['
    local first=1
    local current_version disp_ver
    # Track runtimes already emitted to avoid duplicates: key = "app_id/branch"
    declare -A seen_runtimes=()

    while IFS= read -r remote; do
        [[ -z "$remote" ]] && continue

        # ── Apps ──────────────────────────────────────────────────────────────
        while IFS=$'\t' read -r name app_id branch version; do
            [[ -z "$app_id" ]] && continue
            name="${name//\"/\\\"}"
            disp_ver="${version:-$branch}"
            current_version=$(flatpak info "$app_id//$branch" 2>/dev/null \
                | awk '/Version:/{print $2}') || true
            [[ -z "$current_version" ]] && \
                current_version=$(flatpak info "$app_id" 2>/dev/null \
                    | awk '/Version:/{print $2}') || true
            [[ $first -eq 0 ]] && json+=","
            json+="{\"name\":\"$name\",\"app_id\":\"$app_id\",\"version\":\"$disp_ver\",\"current_version\":\"$current_version\",\"runtime\":false}"
            first=0

            # Check if the updated app requires a runtime branch not yet installed.
            # e.g. Alpaca update needs org.gnome.Platform/x86_64/50 but only 49 is installed.
            local req_runtime rt_id rt_branch installed_rt_branch
            req_runtime=$(flatpak remote-info --system "$remote" "$app_id" 2>/dev/null \
                | awk '/Runtime:/{print $2}') || true
            [[ -z "$req_runtime" ]] && continue
            rt_id=$(echo "$req_runtime" | cut -d/ -f1)
            rt_branch=$(echo "$req_runtime" | cut -d/ -f3)
            [[ -z "$rt_id" || -z "$rt_branch" ]] && continue
            [[ -n "${seen_runtimes[$rt_id/$rt_branch]:-}" ]] && continue
            # Only emit if this branch is NOT already installed
            if ! flatpak list --runtime --columns=application,branch 2>/dev/null \
                    | awk -v id="$rt_id" -v br="$rt_branch" '$1==id && $2==br {found=1} END{exit !found}'; then
                seen_runtimes["$rt_id/$rt_branch"]=1
                installed_rt_branch=$(flatpak list --runtime --columns=application,branch 2>/dev/null \
                    | awk -v id="$rt_id" '$1==id {print $2}' | sort -V | tail -1) || true
                local rt_name
                rt_name=$(flatpak remote-info --system "$remote" "$rt_id//$rt_branch" 2>/dev/null \
                    | awk '/Name:/{$1=""; gsub(/^ /,""); print; exit}') || true
                [[ -z "$rt_name" ]] && rt_name="$rt_id"
                rt_name="${rt_name//\"/\\\"}"
                [[ $first -eq 0 ]] && json+=","
                json+="{\"name\":\"$rt_name\",\"app_id\":\"$rt_id\",\"version\":\"$rt_branch\",\"current_version\":\"$installed_rt_branch\",\"runtime\":true,\"needs_install\":true,\"remote\":\"$remote\"}"
                first=0
            fi
        done < <(flatpak remote-ls --updates "$remote" --app \
            --columns=name,application,branch,version 2>/dev/null) || true

        # ── Runtimes (patch updates to already-installed branches) ────────────
        # version column is often empty for runtimes; branch is the version (e.g. "49").
        while IFS=$'\t' read -r name app_id branch version; do
            [[ -z "$app_id" ]] && continue
            [[ -n "${seen_runtimes[$app_id/$branch]:-}" ]] && continue
            seen_runtimes["$app_id/$branch"]=1
            name="${name//\"/\\\"}"
            disp_ver="${version:-$branch}"
            # Use the latest installed branch of this runtime as current_version
            current_version=$(flatpak list --runtime --columns=application,branch 2>/dev/null \
                | awk -v id="$app_id" '$1==id {print $2}' | sort -V | tail -1) || true
            [[ $first -eq 0 ]] && json+=","
            json+="{\"name\":\"$name\",\"app_id\":\"$app_id\",\"version\":\"$disp_ver\",\"current_version\":\"$current_version\",\"runtime\":true}"
            first=0
        done < <(flatpak remote-ls --updates "$remote" --runtime \
            --columns=name,application,branch,version 2>/dev/null) || true

    done < <(flatpak remotes --system --columns=name 2>/dev/null)

    json+="]}"

    if [[ "$json" == '{"updates": []}' ]]; then
        echo "$json"
        exit 1
    fi
    echo "$json"
    exit 0
}

cmd_upgrade_flatpak() {
    echo "RakuOS: upgrading Flatpak packages..."
    flatpak update -y
    echo "RakuOS: Flatpak upgrade complete."
}

_registry_get_token() {
    local registry_host="$1"
    local repo_path="$2"
    local manifest_url="https://${registry_host}/v2/${repo_path}/manifests/${CHANNEL_TAG}"
    local headers auth_header realm service scope token_url
    headers=$(mktemp)

    local status
    status=$(curl -sS -o /dev/null -D "$headers" \
        -H "Accept: application/vnd.oci.image.manifest.v1+json, application/vnd.docker.distribution.manifest.v2+json" \
        -w '%{http_code}' \
        "$manifest_url") || {
            rm -f "$headers"
            die "Failed to query registry manifest headers from $manifest_url"
        }

    if [[ "$status" == "200" ]]; then
        TOKEN=""
        rm -f "$headers"
        return 0
    fi

    [[ "$status" == "401" ]] || {
        rm -f "$headers"
        die "Unexpected registry response from $manifest_url: HTTP $status"
    }

    auth_header=$(awk 'BEGIN{IGNORECASE=1} /^www-authenticate:/ {sub(/\r$/,""); sub(/^[^:]*:[[:space:]]*/,""); print; exit}' "$headers")
    rm -f "$headers"
    [[ -n "$auth_header" ]] || die "Registry did not provide an authentication challenge."

    realm=$(printf '%s' "$auth_header" | sed -n 's/.*realm="\([^"]*\)".*/\1/p')
    service=$(printf '%s' "$auth_header" | sed -n 's/.*service="\([^"]*\)".*/\1/p')
    scope=$(printf '%s' "$auth_header" | sed -n 's/.*scope="\([^"]*\)".*/\1/p')
    [[ -n "$scope" ]] || scope="repository:${repo_path}:pull"
    [[ -n "$realm" ]] || die "Could not parse registry auth realm from challenge."

    token_url="${realm}?scope=${scope}"
    [[ -n "$service" ]] && token_url="${token_url}&service=${service}"

    TOKEN=$(curl -fsSL "$token_url" | jq -r '.token // .access_token // empty')
    [[ -n "$TOKEN" && "$TOKEN" != "null" ]] \
        || die "Failed to get registry token for $repo_path from $registry_host"
}

_registry_api_get() {
    local registry_host="$1"
    local api_path="$2"

    if [[ -n "${TOKEN:-}" ]]; then
        curl -fsSL \
            -H "Authorization: Bearer $TOKEN" \
            "$api_path"
    else
        curl -fsSL "$api_path"
    fi
}

_canonicalize_repo_url() {
    case "$1" in
        ghcr.io/rakuos/rakuos-base|registry.gitlab.com/rakuos/images/rakuos-base)
            echo "registry.gitlab.com/rakuos/images/rakuos-base"
            ;;
        ghcr.io/rakuos/rakuos-base-nvidia|registry.gitlab.com/rakuos/images/rakuos-base/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-base/nvidia"
            ;;
        ghcr.io/rakuos/rakuos-kde|registry.gitlab.com/rakuos/images/rakuos-kde)
            echo "registry.gitlab.com/rakuos/images/rakuos-kde"
            ;;
        ghcr.io/rakuos/rakuos-kde-nvidia|registry.gitlab.com/rakuos/images/rakuos-kde/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-kde/nvidia"
            ;;
        ghcr.io/rakuos/rakuos-gnome|registry.gitlab.com/rakuos/images/rakuos-gnome)
            echo "registry.gitlab.com/rakuos/images/rakuos-gnome"
            ;;
        ghcr.io/rakuos/rakuos-gnome-nvidia|registry.gitlab.com/rakuos/images/rakuos-gnome/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-gnome/nvidia"
            ;;
        ghcr.io/rakuos/rakuos-cosmic|registry.gitlab.com/rakuos/images/rakuos-cosmic)
            echo "registry.gitlab.com/rakuos/images/rakuos-cosmic"
            ;;
        ghcr.io/rakuos/rakuos-cosmic-nvidia|registry.gitlab.com/rakuos/images/rakuos-cosmic/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-cosmic/nvidia"
            ;;
        *)
            echo "$1"
            ;;
    esac
}

_registry_get_image_info() {
    # Populates globals:
    #   IMAGE_FULL ORIGINAL_REPO_URL REPO_URL REGISTRY_HOST REPO_PATH CURRENT_IMAGE_TAG CURRENT_VERSION
    #   CHANNEL_TAG CURRENT_DATE_TAG TOKEN NEWEST_VERSION NEWEST_DATE_TAG TARGET_TAG
    local bootc_status
    bootc_status=$(sudo bootc status --json 2>/dev/null) || die "bootc status failed"

    IMAGE_FULL=$(echo "$bootc_status" \
        | jq -r '.status.booted.image.image.image // empty' | tr -d '[:space:]')
    ORIGINAL_REPO_URL="${IMAGE_FULL%:*}"
    REPO_URL=$(_canonicalize_repo_url "$ORIGINAL_REPO_URL")
    REGISTRY_HOST="${REPO_URL%%/*}"
    REPO_PATH="${REPO_URL#${REGISTRY_HOST}/}"
    CURRENT_IMAGE_TAG="${IMAGE_FULL##*:}"
    CURRENT_VERSION=$(echo "$bootc_status" \
        | jq -r '.status.booted.image.version // empty' | tr -d '[:space:]')

    [[ -n "$REPO_URL" ]]    || die "Could not detect booted image from bootc status."
    [[ -n "$CURRENT_IMAGE_TAG" ]] || die "Could not detect current image tag from bootc status."
    [[ -n "$CURRENT_VERSION" ]] || die "Could not detect current version from bootc status."
    [[ -n "$REGISTRY_HOST" && "$REPO_PATH" != "$REPO_URL" ]] \
        || die "Could not parse registry repo path from: $REPO_URL"

    if [[ "$CURRENT_IMAGE_TAG" =~ ^[0-9]{8}$ ]]; then
        CHANNEL_TAG="latest"
        CURRENT_DATE_TAG="$CURRENT_IMAGE_TAG"
    elif [[ "$CURRENT_IMAGE_TAG" =~ ^(.+)\.([0-9]{8})$ ]]; then
        CHANNEL_TAG="${BASH_REMATCH[1]}"
        CURRENT_DATE_TAG="${BASH_REMATCH[2]}"
    else
        CHANNEL_TAG="$CURRENT_IMAGE_TAG"
        if [[ "$CURRENT_VERSION" =~ ^${CHANNEL_TAG}\.([0-9]{8})$ ]]; then
            CURRENT_DATE_TAG="${BASH_REMATCH[1]}"
        elif [[ "$CURRENT_VERSION" =~ ^([0-9]{8})$ ]]; then
            CURRENT_DATE_TAG="${BASH_REMATCH[1]}"
        else
            CURRENT_DATE_TAG=""
        fi
    fi

    _registry_get_token "$REGISTRY_HOST" "$REPO_PATH"

    local channel_manifest version_annotation config_digest prefix_regex
    channel_manifest=$(_registry_api_get "$REGISTRY_HOST" \
        "https://${REGISTRY_HOST}/v2/${REPO_PATH}/manifests/${CHANNEL_TAG}")

    version_annotation=$(echo "$channel_manifest" \
        | jq -r '.annotations["org.opencontainers.image.version"] // empty')

    if [[ -z "$version_annotation" ]]; then
        config_digest=$(echo "$channel_manifest" | jq -r '.config.digest // empty')
        if [[ -n "$config_digest" ]]; then
            version_annotation=$(_registry_api_get "$REGISTRY_HOST" \
                "https://${REGISTRY_HOST}/v2/${REPO_PATH}/blobs/${config_digest}" \
                | jq -r '.config.Labels["org.opencontainers.image.version"] // empty')
        fi
    fi

    prefix_regex=$(printf '%s' "$CHANNEL_TAG" | sed 's/[][(){}.^$*+?|\\/]/\\&/g')
    NEWEST_VERSION="$version_annotation"
    NEWEST_DATE_TAG=$(echo "$version_annotation" \
        | sed -E "s/^${prefix_regex}\.//" | grep -oE '[0-9]{8}' | head -n1 || true)
    [[ -n "$NEWEST_DATE_TAG" ]] \
        || die "Could not extract date tag from registry manifest. Got: '$version_annotation'"

    TARGET_TAG="${CHANNEL_TAG}.${NEWEST_DATE_TAG}"
}

cmd_check_image() {
    echo "RakuOS: checking for system image update..." >&2

    local IMAGE_FULL ORIGINAL_REPO_URL REPO_URL REGISTRY_HOST REPO_PATH CURRENT_IMAGE_TAG CURRENT_VERSION CHANNEL_TAG CURRENT_DATE_TAG TOKEN NEWEST_VERSION NEWEST_DATE_TAG TARGET_TAG
    _registry_get_image_info

    echo "Current version: $CURRENT_VERSION" >&2
    echo "Original repo:    $ORIGINAL_REPO_URL" >&2
    echo "Channel tag:     $CHANNEL_TAG" >&2
    echo "Latest version:  $NEWEST_VERSION"  >&2

    if [[ "$ORIGINAL_REPO_URL" == ghcr.io/rakuos/* ]] && [[ "$REPO_URL" != "$ORIGINAL_REPO_URL" ]]; then
        echo "{\"update\":true,\"type\":\"switch\",\"booted\":\"$CURRENT_VERSION\",\"available\":\"$CHANNEL_TAG\",\"repo\":\"$REPO_URL\"}"
        exit 0
    fi

    # 1. New date tag available — switch to it
    if [[ "$CURRENT_DATE_TAG" =~ ^[0-9]{8}$ ]]; then
        if [[ "$NEWEST_DATE_TAG" -gt "$CURRENT_DATE_TAG" ]]; then
            echo "{\"update\":true,\"type\":\"switch\",\"booted\":\"$CURRENT_VERSION\",\"available\":\"$TARGET_TAG\",\"repo\":\"$REPO_URL\"}"
            exit 0
        fi
    fi

    # 2. Same tag — check if current tag has updated content via bootc upgrade --check
    echo "RakuOS: same tag, checking for content updates..." >&2
    local check_out
    check_out=$(sudo bootc upgrade --check 2>&1) || true

    if echo "$check_out" | grep -q "No changes"; then
        echo "{\"update\":false,\"booted\":\"$CURRENT_VERSION\",\"available\":\"$CURRENT_VERSION\"}"
        exit 1
    fi

    # bootc found changes in current tag (hotfix/content update)
    echo "{\"update\":true,\"type\":\"upgrade\",\"booted\":\"$CURRENT_VERSION\",\"available\":\"$CURRENT_IMAGE_TAG\",\"repo\":\"$REPO_URL\"}"
    exit 0
}

cmd_upgrade_image() {
    echo "RakuOS: checking for system image update..."

    local IMAGE_FULL ORIGINAL_REPO_URL REPO_URL REGISTRY_HOST REPO_PATH CURRENT_IMAGE_TAG CURRENT_VERSION CHANNEL_TAG CURRENT_DATE_TAG TOKEN NEWEST_VERSION NEWEST_DATE_TAG TARGET_TAG
    _registry_get_image_info

    if [[ "$ORIGINAL_REPO_URL" == ghcr.io/rakuos/* ]] && [[ "$REPO_URL" != "$ORIGINAL_REPO_URL" ]]; then
        echo "RakuOS: migrating legacy GHCR image to GitLab channel $REPO_URL:$CHANNEL_TAG..."
        bootc switch "$REPO_URL:$CHANNEL_TAG"
        echo "RakuOS: system image update staged. Reboot to apply."
        exit 0
    fi

    # 1. New date tag — switch to it
    if [[ "$CURRENT_DATE_TAG" =~ ^[0-9]{8}$ ]] \
        && [[ "$NEWEST_DATE_TAG" -gt "$CURRENT_DATE_TAG" ]]; then
        echo "RakuOS: switching to new image tag $REPO_URL:$TARGET_TAG..."
        bootc switch "$REPO_URL:$TARGET_TAG"
        echo "RakuOS: system image update staged. Reboot to apply."
        exit 0
    fi

    # 2. Same tag — run bootc upgrade for content updates (hotfixes)
    echo "RakuOS: upgrading current image tag $CURRENT_IMAGE_TAG..."
    bootc upgrade
    echo "RakuOS: system image update staged. Reboot to apply."
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

case "$COMMAND" in
    check)           cmd_check ;;
    upgrade)         cmd_upgrade ;;
    upgrade-package) cmd_upgrade_package "${2:-}" ;;
    check-flatpak)   cmd_check_flatpak ;;
    upgrade-flatpak) cmd_upgrade_flatpak ;;
    check-image)     cmd_check_image ;;
    upgrade-image)   cmd_upgrade_image ;;
    *) die "Unknown command: $COMMAND. Use check|upgrade|check-flatpak|upgrade-flatpak|check-image|upgrade-image" ;;
esac

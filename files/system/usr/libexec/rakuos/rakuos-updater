#!/usr/bin/env bash
set -euo pipefail

echo "Starting RakuOS Auto Updater (bootc)..."

canonicalize_repo_url() {
    case "$1" in
        ghcr.io/rakuos/rakuos-base|registry.gitlab.com/rakuos/images/rakuos-base)
            echo "registry.gitlab.com/rakuos/images/rakuos-base"
            ;;
        ghcr.io/rakuos/rakuos-base-nvidia|registry.gitlab.com/rakuos/images/rakuos-base/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-base/nvidia"
            ;;
        ghcr.io/rakuos/rakuos-kde|registry.gitlab.com/rakuos/images/rakuos-kde)
            echo "registry.gitlab.com/rakuos/images/rakuos-kde"
            ;;
        ghcr.io/rakuos/rakuos-kde-nvidia|registry.gitlab.com/rakuos/images/rakuos-kde/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-kde/nvidia"
            ;;
        ghcr.io/rakuos/rakuos-gnome|registry.gitlab.com/rakuos/images/rakuos-gnome)
            echo "registry.gitlab.com/rakuos/images/rakuos-gnome"
            ;;
        ghcr.io/rakuos/rakuos-gnome-nvidia|registry.gitlab.com/rakuos/images/rakuos-gnome/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-gnome/nvidia"
            ;;
        ghcr.io/rakuos/rakuos-cosmic|registry.gitlab.com/rakuos/images/rakuos-cosmic)
            echo "registry.gitlab.com/rakuos/images/rakuos-cosmic"
            ;;
        ghcr.io/rakuos/rakuos-cosmic-nvidia|registry.gitlab.com/rakuos/images/rakuos-cosmic/nvidia)
            echo "registry.gitlab.com/rakuos/images/rakuos-cosmic/nvidia"
            ;;
        *)
            echo "$1"
            ;;
    esac
}

# -------------------------------
# Detect currently running image
# -------------------------------
BOOTC_STATUS=$(bootc status --json)

# Full image string e.g. ghcr.io/rakuos/rakuos-kde:latest
IMAGE_FULL=$(echo "$BOOTC_STATUS" | jq -r '.status.booted.image.image.image // empty' | tr -d '[:space:]')

# Strip :tag to get base repo URL
ORIGINAL_REPO_URL="${IMAGE_FULL%:*}"
REPO_URL=$(canonicalize_repo_url "$ORIGINAL_REPO_URL")
CURRENT_IMAGE_TAG="${IMAGE_FULL##*:}"

# Get current version field e.g. "latest.20260306" or "staging.20260306"
CURRENT_VERSION=$(echo "$BOOTC_STATUS" | jq -r '.status.booted.image.version // empty' | tr -d '[:space:]')

if [[ -z "$REPO_URL" ]]; then
    echo "ERROR: Could not detect booted image from bootc status."
    exit 1
fi

if [[ -z "$CURRENT_IMAGE_TAG" ]]; then
    echo "ERROR: Could not detect current image tag from bootc status."
    exit 1
fi

if [[ -z "$CURRENT_VERSION" ]]; then
    echo "ERROR: Could not detect current version from bootc status."
    exit 1
fi

if [[ "$CURRENT_IMAGE_TAG" =~ ^[0-9]{8}$ ]]; then
    CHANNEL_TAG="latest"
    CURRENT_DATE_TAG="$CURRENT_IMAGE_TAG"
elif [[ "$CURRENT_IMAGE_TAG" =~ ^(.+)\.([0-9]{8})$ ]]; then
    CHANNEL_TAG="${BASH_REMATCH[1]}"
    CURRENT_DATE_TAG="${BASH_REMATCH[2]}"
else
    CHANNEL_TAG="$CURRENT_IMAGE_TAG"
    if [[ "$CURRENT_VERSION" =~ ^${CHANNEL_TAG}\.([0-9]{8})$ ]]; then
        CURRENT_DATE_TAG="${BASH_REMATCH[1]}"
    elif [[ "$CURRENT_VERSION" =~ ^([0-9]{8})$ ]]; then
        CURRENT_DATE_TAG="${BASH_REMATCH[1]}"
    else
        CURRENT_DATE_TAG=""
    fi
fi

echo "Current image repo: $REPO_URL"
echo "Original image repo: $ORIGINAL_REPO_URL"
echo "Current image tag:  $CURRENT_IMAGE_TAG"
echo "Current version:    $CURRENT_VERSION"
echo "Channel tag:        $CHANNEL_TAG"

# -------------------------------
# Get registry token if needed
# -------------------------------
REGISTRY_HOST="${REPO_URL%%/*}"
REPO_PATH="${REPO_URL#${REGISTRY_HOST}/}"

if [[ -z "$REGISTRY_HOST" || "$REPO_PATH" == "$REPO_URL" ]]; then
    echo "ERROR: Could not parse registry repo path from: $REPO_URL"
    exit 1
fi

HEADERS_FILE=$(mktemp)
STATUS=$(curl -sS -o /dev/null -D "$HEADERS_FILE" \
    -H "Accept: application/vnd.oci.image.manifest.v1+json, application/vnd.docker.distribution.manifest.v2+json" \
    -w '%{http_code}' \
    "https://${REGISTRY_HOST}/v2/${REPO_PATH}/manifests/${CHANNEL_TAG}") || {
        rm -f "$HEADERS_FILE"
        echo "ERROR: Failed to query registry headers for $REPO_URL"
        exit 1
    }

TOKEN=""
if [[ "$STATUS" == "401" ]]; then
    AUTH_HEADER=$(awk 'BEGIN{IGNORECASE=1} /^www-authenticate:/ {sub(/\r$/,""); sub(/^[^:]*:[[:space:]]*/,""); print; exit}' "$HEADERS_FILE")
    REALM=$(printf '%s' "$AUTH_HEADER" | sed -n 's/.*realm="\([^"]*\)".*/\1/p')
    SERVICE=$(printf '%s' "$AUTH_HEADER" | sed -n 's/.*service="\([^"]*\)".*/\1/p')
    SCOPE=$(printf '%s' "$AUTH_HEADER" | sed -n 's/.*scope="\([^"]*\)".*/\1/p')
    [[ -n "$SCOPE" ]] || SCOPE="repository:${REPO_PATH}:pull"

    if [[ -z "$REALM" ]]; then
        rm -f "$HEADERS_FILE"
        echo "ERROR: Could not parse registry auth realm for $REPO_URL"
        exit 1
    fi

    TOKEN_URL="${REALM}?scope=${SCOPE}"
    [[ -n "$SERVICE" ]] && TOKEN_URL="${TOKEN_URL}&service=${SERVICE}"
    TOKEN=$(curl -fsSL "$TOKEN_URL" | jq -r '.token // .access_token // empty')
    if [[ -z "$TOKEN" || "$TOKEN" == "null" ]]; then
        rm -f "$HEADERS_FILE"
        echo "ERROR: Failed to get registry token for $REPO_PATH"
        exit 1
    fi
elif [[ "$STATUS" != "200" ]]; then
    rm -f "$HEADERS_FILE"
    echo "ERROR: Unexpected registry response for $REPO_URL: HTTP $STATUS"
    exit 1
fi
rm -f "$HEADERS_FILE"

# -------------------------------
# Get newest version annotation from the current channel manifest
# -------------------------------
if [[ -n "$TOKEN" ]]; then
    LATEST_MANIFEST=$(curl -fsSL \
        -H "Authorization: Bearer $TOKEN" \
        -H "Accept: application/vnd.oci.image.manifest.v1+json" \
        "https://${REGISTRY_HOST}/v2/${REPO_PATH}/manifests/${CHANNEL_TAG}")
else
    LATEST_MANIFEST=$(curl -fsSL \
        -H "Accept: application/vnd.oci.image.manifest.v1+json" \
        "https://${REGISTRY_HOST}/v2/${REPO_PATH}/manifests/${CHANNEL_TAG}")
fi

# Try manifest-level annotations first
VERSION_ANNOTATION=$(echo "$LATEST_MANIFEST" \
| jq -r '.annotations["org.opencontainers.image.version"] // empty')

# Fallback: check config blob labels
if [[ -z "$VERSION_ANNOTATION" ]]; then
    CONFIG_DIGEST=$(echo "$LATEST_MANIFEST" | jq -r '.config.digest // empty')
    if [[ -n "$CONFIG_DIGEST" ]]; then
        if [[ -n "$TOKEN" ]]; then
            VERSION_ANNOTATION=$(curl -fsSL \
                -H "Authorization: Bearer $TOKEN" \
                "https://${REGISTRY_HOST}/v2/${REPO_PATH}/blobs/$CONFIG_DIGEST" \
            | jq -r '.config.Labels["org.opencontainers.image.version"] // empty')
        else
            VERSION_ANNOTATION=$(curl -fsSL \
                "https://${REGISTRY_HOST}/v2/${REPO_PATH}/blobs/$CONFIG_DIGEST" \
            | jq -r '.config.Labels["org.opencontainers.image.version"] // empty')
        fi
    fi
fi

PREFIX_REGEX=$(printf '%s' "$CHANNEL_TAG" | sed 's/[][(){}.^$*+?|\\/]/\\&/g')
NEWEST_TAG=$(echo "$VERSION_ANNOTATION" | sed -E "s/^${PREFIX_REGEX}\.//" | grep -oE '[0-9]{8}' | head -n1 || true)

if [[ -z "$NEWEST_TAG" ]]; then
    echo "ERROR: Could not extract date from channel manifest annotation."
    echo "Version annotation value: '$VERSION_ANNOTATION'"
    echo "Manifest response:"
    echo "$LATEST_MANIFEST" | jq . || echo "$LATEST_MANIFEST"
    exit 1
fi

TARGET_TAG="${CHANNEL_TAG}.${NEWEST_TAG}"

echo "Latest version on registry: $VERSION_ANNOTATION"
echo "Latest target tag:      $TARGET_TAG"

if [[ "$ORIGINAL_REPO_URL" == ghcr.io/rakuos/* ]] && [[ "$REPO_URL" != "$ORIGINAL_REPO_URL" ]]; then
    echo "Legacy GHCR image detected — switching to GitLab channel $REPO_URL:$CHANNEL_TAG..."
    bootc switch "$REPO_URL:$CHANNEL_TAG"

    echo "New deployment staged — notifying user."

    ACTIVE_USER=$(loginctl list-sessions --no-legend | awk '{print $3}' | head -n1)

    if [[ -n "$ACTIVE_USER" ]] && command -v notify-send &>/dev/null; then
        USER_UID=$(id -u "$ACTIVE_USER")
        USER_RUNTIME="/run/user/$USER_UID"

        echo "Sending notification to: $ACTIVE_USER"

        ACTION=$(sudo -u "$ACTIVE_USER" \
            DBUS_SESSION_BUS_ADDRESS="unix:path=$USER_RUNTIME/bus" \
            DISPLAY=:0 \
            notify-send \
            --app-name="RakuOS Updater" \
            --icon=system-software-update \
            --urgency=normal \
            --expire-time=0 \
            --action=reboot="Reboot Now" \
            --action=later="Later" \
            --wait \
            "RakuOS Update Ready" \
        "Image $CHANNEL_TAG is staged. Layered packages will be upgraded on Reboot. Reboot to apply." 2>/dev/null || echo "later")

        case "$ACTION" in
            reboot)
                echo "User chose reboot — rebooting now."
                systemctl reboot
                exit 0
            ;;
            *)
                echo "User chose later or dismissed."
                exit 0
            ;;
        esac
    else
        echo "No active graphical session — skipping notification."
        exit 0
    fi
fi

# -------------------------------
# Compare tags — skip if already on newest
# -------------------------------
if echo "$CURRENT_DATE_TAG" | grep -qE '^[0-9]{8}$'; then
    if [[ "$CURRENT_DATE_TAG" -ge "$NEWEST_TAG" ]]; then
        bootc upgrade
        # -------------------------------
        # Notify user
        # -------------------------------
        echo "New deployment staged — notifying user."
        
        ACTIVE_USER=$(loginctl list-sessions --no-legend | awk '{print $3}' | head -n1)
        
        if [[ -n "$ACTIVE_USER" ]] && command -v notify-send &>/dev/null; then
            USER_UID=$(id -u "$ACTIVE_USER")
            USER_RUNTIME="/run/user/$USER_UID"
            
            echo "Sending notification to: $ACTIVE_USER"
            
            ACTION=$(sudo -u "$ACTIVE_USER" \
                DBUS_SESSION_BUS_ADDRESS="unix:path=$USER_RUNTIME/bus" \
                DISPLAY=:0 \
                notify-send \
                --app-name="RakuOS Updater" \
                --icon=system-software-update \
                --urgency=normal \
                --expire-time=0 \
                --action=reboot="Reboot Now" \
                --action=later="Later" \
                --wait \
                "RakuOS Update Ready" \
            "Image $TARGET_TAG is staged. Layered packages will be upgraded on Reboot. Reboot to apply." 2>/dev/null || echo "later")
            
            case "$ACTION" in
                reboot)
                    echo "User chose reboot — rebooting now."
                    systemctl reboot
                    exit 0
                ;;
                *)
                    echo "User chose later or dismissed."
                    exit 0
                ;;
            esac
        else
            echo "No active graphical session — skipping notification."
            exit 0
        fi
        
        echo "RakuOS Auto Updater finished."
        exit 0
    fi
else
    echo "Current version is '$CURRENT_VERSION' (non-date), will switch to target tag $TARGET_TAG."
fi

# -------------------------------
# Switch to newest dated tag via bootc
# -------------------------------
echo "New image available: $TARGET_TAG (current: $CURRENT_IMAGE_TAG) — updating..."

bootc switch "$REPO_URL:$TARGET_TAG"

# -------------------------------
# Notify user
# -------------------------------
echo "New deployment staged — notifying user."

ACTIVE_USER=$(loginctl list-sessions --no-legend | awk '{print $3}' | head -n1)

if [[ -n "$ACTIVE_USER" ]] && command -v notify-send &>/dev/null; then
    USER_UID=$(id -u "$ACTIVE_USER")
    USER_RUNTIME="/run/user/$USER_UID"
    
    echo "Sending notification to: $ACTIVE_USER"
    
    ACTION=$(sudo -u "$ACTIVE_USER" \
        DBUS_SESSION_BUS_ADDRESS="unix:path=$USER_RUNTIME/bus" \
        DISPLAY=:0 \
        notify-send \
        --app-name="RakuOS Updater" \
        --icon=system-software-update \
        --urgency=normal \
        --expire-time=0 \
        --action=reboot="Reboot Now" \
        --action=later="Later" \
        --wait \
        "RakuOS Update Ready" \
    "Image $TARGET_TAG is staged. Layered packages will be upgraded on Reboot. Reboot to apply." 2>/dev/null || echo "later")
    
    case "$ACTION" in
        reboot)
            echo "User chose reboot — rebooting now."
            systemctl reboot
        ;;
        *)
            echo "User chose later or dismissed."
        ;;
    esac
else
    echo "No active graphical session — skipping notification."
fi

echo "RakuOS Auto Updater finished."
